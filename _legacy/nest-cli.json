{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "api/src",
  "entryFile": "main",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "../../public/**/*", "outDir": "./dist/public", "watchAssets": true }
    ]
  }
}
