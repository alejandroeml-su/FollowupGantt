{
  "version": 2,
  "builds": [
    {
      "src": "api/src/main.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**"]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/src/main.ts" },
    { "src": "/(.*\\.(css|js|png|jpg|svg|ico))", "dest": "public/$1" },
    { "src": "/", "dest": "public/index.html" },
    { "src": "/(kanban|gantt|itil|dashboard|sprints|projects)", "dest": "public/$1.html" },
    { "src": "/(.*)", "dest": "api/src/main.ts" }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_ANON_KEY": "@supabase_anon_key",
    "SUPABASE_SERVICE_KEY": "@supabase_service_key"
  }
}
