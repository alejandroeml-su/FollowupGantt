generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// ENUMERADORES (Tipos definidos)
// ---------------------------------------------------------

enum TaskType {
  AGILE_STORY
  PMI_TASK
  ITIL_TICKET
}

enum DependencyType {
  FINISH_TO_START // FS
  START_TO_START // SS
  FINISH_TO_FINISH // FF
  START_TO_FINISH // SF
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Tipos soportados por el módulo de Custom Fields (Ola P1, Equipo 3).
// Cada definición de campo tiene un tipo fijo; la validación zod se
// despacha por este enum en el server action.
enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  URL
}

// Ola P1 · Centro de notificaciones in-app.
// Añadido cuando todavía no existe sesión real: el `userId` lo provee el
// caller (Sidebar hardcodea SUPER_ADMIN; futuro hook de auth).
enum NotificationType {
  MENTION
  TASK_ASSIGNED
  COMMENT_REPLY
  BASELINE_CAPTURED
  DEPENDENCY_VIOLATION
  IMPORT_COMPLETED
}

// Ola P2 · Equipo P2-1 — Vistas guardadas multi-surface.
// Cada SavedView fija una "superficie" (qué tablero la consume) para que
// los filtros, grouping y columnPrefs sean coherentes con la UI destino.
enum ViewSurface {
  LIST
  KANBAN
  GANTT
  CALENDAR
  TABLE
}

// Ola P2 · Equipo P2-3 — Recurrencia de tareas (subset iCalendar RRULE).
// Frecuencia base que combinada con `interval`, `byweekday` y `bymonthday`
// describe patrones tipo "cada 2 semanas, lun y mié" o "el día 15 de cada mes".
enum RecurrenceFreq {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// Ola P2 · Equipo P2-4 · Goals & OKRs.
// Estado del Objective: ON_TRACK / AT_RISK / OFF_TRACK derivado de la
// función `classifyGoalStatus` (heurística progress vs tiempo transcurrido).
// COMPLETED / CANCELLED se setean manualmente desde la UI.
enum GoalStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
  CANCELLED
}

// Tipo de métrica de un Key Result. Define cómo se calcula `currentValue`
// y se renderiza el progreso:
//   - PERCENT: 0-100, manual.
//   - NUMERIC: cualquier número con `unit` (USD, users, …); progress =
//     currentValue / targetValue.
//   - BOOLEAN: true/false (1 = done, 0 = pending).
//   - TASKS_COMPLETED: progress derivado de tasks vinculadas.
enum KeyResultMetric {
  PERCENT
  NUMERIC
  BOOLEAN
  TASKS_COMPLETED
}

// ---------------------------------------------------------
// ENTIDADES PRINCIPALES
// ---------------------------------------------------------

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique

  // ── Auth (P1 MVP) ─────────────────────────────────────────────
  // Hash PBKDF2 + salt (formato `pbkdf2$<iter>$<saltB64>$<hashB64>`).
  // Nullable porque puede provenir de SSO en futuras iteraciones.
  password      String?
  emailVerified DateTime?

  accounts Account[]
  sessions Session[]

  // Roles y Permisos
  roles UserRole[]

  // Equipos
  teams TeamMember[]

  // Asignaciones a Proyectos (para restringir edición)
  projectAssignments ProjectAssignment[]

  // Relaciones
  managedProjects    Project[]          @relation("ProjectManager")
  tasks              Task[]             @relation("TaskAssignee")
  taskCollaborations TaskCollaborator[] @relation("TaskCollaborator")
  comments           Comment[]          @relation("CommentAuthor")
  history            TaskHistory[]
  attachments        Attachment[]
  mindMaps           MindMap[]          @relation("MindMapOwner")

  // Time Tracking (Ola P1, Equipo 4) — un usuario tiene múltiples entries
  // y un historial de tarifas horarias (efectivas por rango de fechas).
  timeEntries TimeEntry[]
  hourlyRates UserHourlyRate[]

  // Ola P1 · Centro de notificaciones in-app (HU-N1.x).
  notifications          Notification[]
  notificationPreference NotificationPreference?

  // Ola P2 · Vistas guardadas (Equipo P2-1).
  savedViews SavedView[]

  // Ola P2 · Templates creados por el usuario (Equipo P2-3).
  taskTemplates TaskTemplate[] @relation("TaskTemplateAuthor")

  // Ola P2 · Equipo P2-4 · Goals & OKRs.
  // Objetivos donde este usuario figura como `owner`. La relación inversa
  // de `parentId/children` no incluye al User: es propiedad estructural del
  // Goal.
  ownedGoals Goal[] @relation("GoalOwner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Auth: tablas estándar Auth.js / NextAuth (P1 MVP) ─────────────
// Aunque hoy implementamos credentials con sesión propia (cookie firmada
// + tabla Session), mantenemos el shape de Account compatible para
// migrar a NextAuth + Prisma adapter sin romper datos cuando se agreguen
// providers SSO (Google/Microsoft) en una iteración posterior.

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // AGENTE, ADMIN, SUPER_ADMIN
  description String?
  permissions Json? // Ejemplo: { "allowedViews": ["list", "kanban", "gantt"] }

  users UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Team {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  members TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

model ProjectAssignment {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

// Módulo de Estructura Organizacional
model Gerencia {
  id          String  @id @default(uuid())
  name        String  @unique // Ejemplo: "OPERACIONES", "FINANZAS"
  description String?

  areas Area[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Area {
  id          String  @id @default(uuid())
  name        String // Ejemplo: "Desarrollo", "Infraestructura"
  description String?

  // Relación con Gerencia (obligatoria)
  gerenciaId String
  gerencia   Gerencia @relation(fields: [gerenciaId], references: [id], onDelete: Cascade)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)

  // Área / Gerencia
  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])

  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  // KPIs financieros y de cronograma (EVM - Earned Value Management)
  // Se pueden guardar calculados o dejarlos para consulta dinámica
  cpi Float? // Cost Performance Index
  spi Float? // Schedule Performance Index

  // Calendario laboral aplicable al proyecto (Ola P1.5).
  // Si NULL → CPM y workload usan días corridos (legacy).
  calendarId String?
  calendar   WorkCalendar? @relation(fields: [calendarId], references: [id])

  // Relaciones
  phases          Phase[]
  sprints         Sprint[]
  columns         BoardColumn[]
  tasks           Task[]
  baselines       Baseline[]
  assignments     ProjectAssignment[]
  mindMaps        MindMap[]
  // Custom Fields configurables por proyecto (Ola P1, Equipo 3).
  customFieldDefs CustomFieldDef[]

  // Templates por proyecto (Ola P2, Equipo P2-3). Un template puede ser
  // global (`projectId = null`) o per-project; los globales se reutilizan
  // entre todos los proyectos y los per-project sólo aparecen en su lista.
  taskTemplates TaskTemplate[]

  // Ola P2 · Equipo P2-4 · Goals & OKRs.
  // Objetivos asociados al proyecto. `onDelete: SetNull` en Goal preserva
  // los OKRs históricos aunque se elimine el proyecto.
  goals Goal[]

  // Ola P4 · Equipo P4-5 · Integraciones externas.
  // Integraciones (Slack/Teams/GitHub) ancladas a este proyecto. `projectId`
  // es opcional en `Integration`: las integraciones globales del workspace
  // viven con `projectId = null` y aplican a todos los proyectos.
  integrations Integration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Fases del Proyecto (Waterfall / PMI)
model Phase {
  id    String @id @default(uuid())
  name  String
  order Int    @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Módulo Agile: Sprints y Columnas Kanban
//
// Ola P2 · Equipo P2-2 — Story Points + Velocity:
//   - `capacity` = puntos de historia comprometidos por el equipo al
//     planificar el sprint (input humano).
//   - `startedAt` / `endedAt` = timestamps reales del lifecycle (distintos
//     de `startDate`/`endDate`, que son la planificación). Se setean al
//     invocar `startSprint` / `endSprint` respectivamente.
//   - `velocityActual` = suma de `storyPoints` de tasks DONE en el sprint
//     al momento de cerrarlo. Se persiste para que el VelocityChart no
//     dependa de re-calcular sobre el grafo de tasks (que puede mutar
//     después del cierre).
model Sprint {
  id        String        @id @default(uuid())
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  status    ProjectStatus @default(PLANNING)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // ── Agile metrics (Ola P2) ──────────────────────────────────────
  capacity        Int?
  startedAt       DateTime?
  endedAt         DateTime?
  velocityActual  Int?

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BoardColumn {
  id       String @id @default(uuid())
  name     String
  order    Int
  wipLimit Int? // Límite de Work in Progress (AC Kanban)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tarea Universal: Soporta Story (Agile), Hito/Tarea (Gantt) y Ticket (ITIL)
model Task {
  id          String     @id @default(uuid())
  mnemonic    String? // Ejemplo: "PROJ-1"
  title       String
  description String?
  type        TaskType   @default(AGILE_STORY)
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)

  // Jerarquía (Subtareas)
  parentId String?
  parent   Task?   @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]  @relation("SubTasks")

  // Relaciones de Agrupación
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  phaseId String?
  phase   Phase?  @relation(fields: [phaseId], references: [id])

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id])

  columnId String?
  column   BoardColumn? @relation(fields: [columnId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // Módulo PMI (Gantt)
  startDate   DateTime?
  endDate     DateTime?
  progress    Int       @default(0) // 0 - 100%
  isMilestone Boolean   @default(false)

  // Dependencias (Gantt)
  predecessors TaskDependency[] @relation("SuccessorTask")
  successors   TaskDependency[] @relation("PredecessorTask")

  // Módulo ITIL (SLA Management)
  slaResponseLimit   DateTime? // Límite de tiempo para responder
  slaResolutionLimit DateTime? // Límite de tiempo para resolver
  isEscalated        Boolean   @default(false)

  // EVM y KPIs (Horas / Costos)
  plannedValue Float? // PV: Valor Planificado (Costo o esfuerzo base)
  actualCost   Float? // AC: Costo/Esfuerzo real incurrido
  earnedValue  Float? // EV: Valor Ganado (PV * progress/100)

  // Ordenamiento visual en List/Kanban (ADR-001 fractional indexing)
  position Float @default(0)

  // Soft archive para acción "Archivar" del menú contextual
  archivedAt DateTime?

  // Etiquetas libres para filtros/búsqueda
  tags String[] @default([])

  // ── Agile · Story Points (Ola P2) ──────────────────────────────
  // Estimación en escala Fibonacci (1, 2, 3, 5, 8, 13, 21). Nullable
  // porque las tareas PMI/ITIL no se estiman en puntos. La validación
  // del valor permitido vive en el server action (`assignTaskToSprint`
  // y `setTaskStoryPoints`); aquí dejamos el tipo amplio para no atar
  // futuros equipos que quieran extender la escala.
  storyPoints Int?

  // Enlace externo de referencia (Confluence, Figma, ticket externo, etc.)
  referenceUrl String?

  // Seguimiento y comentarios
  comments      Comment[]
  history       TaskHistory[]
  attachments   Attachment[]
  collaborators TaskCollaborator[]

  // Enlace opcional desde nodos de Mapa Mental
  mindMapNodes MindMapNode[] @relation("TaskMindMapNodes")

  // Time Tracking (Ola P1, Equipo 4). La suma de `timeEntries.cost`
  // alimenta `actualCost` real para EVM (HU-2.1+).
  timeEntries TimeEntry[]

  // Custom Fields configurables (Ola P1). Una tarea acumula valores para
  // las definiciones del proyecto; cascade desde la definición y desde la
  // tarea garantiza limpieza al borrar el padre o la propia tarea.
  customFieldValues CustomFieldValue[]

  // Ola P2 · Equipo P2-3 — Recurrencia.
  //
  // Si la tarea fue generada por una RecurrenceRule (cron `scheduleAll`)
  // queda enlazada aquí; al borrar la regla la FK se setea a NULL para
  // preservar el histórico de tareas materializadas.
  recurrenceRuleId String?
  recurrenceRule   RecurrenceRule? @relation("RecurringTaskInstances", fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  // Fecha "lógica" de la ocurrencia (UTC midnight) usada como llave única
  // junto con `recurrenceRuleId` para garantizar idempotencia del scheduler:
  // si una invocación catch-up corre dos veces no se duplican tasks.
  occurrenceDate   DateTime?

  // Ola P2 · Equipo P2-4 · Goals & OKRs.
  // KRs (con metric=TASKS_COMPLETED) que esta tarea contribuye a alcanzar.
  // M:N a través de la tabla implícita "_KeyResultTasks".
  keyResults KeyResult[] @relation("KeyResultTasks")

  // Ola P4 · Equipo P4-5 · Integraciones · GitHub.
  // Vínculos de la tarea a issues/PRs externos en GitHub. Una tarea puede
  // tener múltiples links (ej. issue de bug + PR que lo resuelve).
  githubLinks TaskGitHubLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recurrenceRuleId, occurrenceDate])
  @@index([projectId, columnId, position])
  @@index([projectId, parentId, position])
  @@index([archivedAt])
}

// Colaboradores adicionales de una tarea (M:N Task ↔ User).
// El `assigneeId` único de Task sigue siendo el responsable principal;
// los colaboradores aquí son destinatarios extra para notificaciones de
// mención y visibilidad del trabajo compartido.
model TaskCollaborator {
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("TaskCollaborator", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// Comentarios / Seguimiento de tareas
model Comment {
  id         String  @id @default(uuid())
  content    String
  isInternal Boolean @default(false) // Seguimiento interno vs externo

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation("CommentAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

// Historial de cambios / Auditoría
model TaskHistory {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  field    String // Campo modificado: "status", "priority", "assigneeId", etc.
  oldValue String?
  newValue String?

  createdAt DateTime @default(now())
}

// Adjuntos / Archivos de respaldo
model Attachment {
  id       String  @id @default(uuid())
  filename String
  url      String
  size     Int?
  mimetype String?

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// Dependencias entre tareas (FS, SS, FF, SF)
model TaskDependency {
  id String @id @default(uuid())

  predecessorId String
  predecessor   Task   @relation("PredecessorTask", fields: [predecessorId], references: [id], onDelete: Cascade)

  successorId String
  successor   Task   @relation("SuccessorTask", fields: [successorId], references: [id], onDelete: Cascade)

  type DependencyType @default(FINISH_TO_START)

  // Lag/Lead en días aplicado a la dependencia. Positivo = espera obligatoria
  // (ej. FS+2 = sucesor inicia 2 días después de que el predecesor termine);
  // negativo = lead/solapamiento (ej. FS-1 = sucesor inicia 1 día antes).
  // Usado por el cálculo CPM (forward/backward pass).
  lagDays Int @default(0)

  @@unique([predecessorId, successorId])
}

// Módulo PMI: Líneas Base (Snapshots para calcular Schedule Variance)
model Baseline {
  id           String  @id @default(uuid())
  version      Int // Versión 1, 2, 3... (por proyecto, monótonamente creciente)
  snapshotData Json // Json estructurado con el estado de las tareas (fechas, PV, EV, AC)
  // Etiqueta libre opcional capturada por el usuario para distinguir
  // versiones (≤80 chars). Persistida como columna primera-clase para
  // permitir mostrarla sin parsear el JSON.
  label        String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // HU-3.1 · Garantía de unicidad por proyecto+versión. Sirve también
  // como guard contra race conditions cuando dos clientes capturan
  // simultáneamente: la 2ª transacción falla con P2002 y la action
  // reintenta con max(version)+1.
  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Módulo Calendarios Laborales (Ola P1.5)
// ─────────────────────────────────────────────────────────────

model WorkCalendar {
  id           String  @id @default(uuid())
  name         String
  isDefault    Boolean @default(false)
  // Bitmask de días laborables (bit 0 = lun, bit 6 = dom).
  // Default: lun-vie = 0b0011111 = 31 (sin sábado ni domingo).
  workdays     Int     @default(31)
  // Horas estándar de jornada laboral (8.00 por defecto).
  workdayHours Decimal @default(8.00) @db.Decimal(4, 2)

  holidays Holiday[]
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id         String       @id @default(uuid())
  calendarId String
  calendar   WorkCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  // Fecha del festivo (almacenada como UTC midnight).
  date       DateTime
  name       String
  // Si true ⇒ se repite cada año (se compara solo mes/día).
  recurring  Boolean      @default(false)

  createdAt DateTime @default(now())

  @@unique([calendarId, date])
  @@index([calendarId, date])
}

// ─────────────────────────────────────────────────────────────
// Módulo Mapas Mentales (estilo MindMup 3)
// ─────────────────────────────────────────────────────────────

model MindMap {
  id          String  @id @default(uuid())
  title       String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("MindMapOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  nodes MindMapNode[]
  edges MindMapEdge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([ownerId])
}

model MindMapNode {
  id String @id @default(uuid())

  mindMapId String
  mindMap   MindMap @relation(fields: [mindMapId], references: [id], onDelete: Cascade)

  label  String  @default("Nuevo nodo")
  note   String? // Markdown o texto libre (nota expandida)
  x      Float   @default(0)
  y      Float   @default(0)
  color  String?
  isRoot Boolean @default(false)

  // Enlace opcional a Task
  taskId String?
  task   Task?   @relation("TaskMindMapNodes", fields: [taskId], references: [id], onDelete: SetNull)

  sourceEdges MindMapEdge[] @relation("EdgeSource")
  targetEdges MindMapEdge[] @relation("EdgeTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mindMapId])
  @@index([taskId])
}

model MindMapEdge {
  id String @id @default(uuid())

  mindMapId String
  mindMap   MindMap @relation(fields: [mindMapId], references: [id], onDelete: Cascade)

  sourceId String
  source   MindMapNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId String
  target   MindMapNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  label String?

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId])
  @@index([mindMapId])
}

// ─────────────────────────────────────────────────────────────
// Módulo Time Tracking (Ola P1 · Equipo 4)
//
// Permite que cada miembro registre tiempo trabajado en tareas, ya sea
// con un timer en vivo (`endedAt = null`) o como entrada manual con
// rango cerrado. La suma de `cost` por tarea alimenta `Task.actualCost`
// real para EVM (HU-2.1+), reemplazando el valor estimado.
//
// Decisiones:
//   1. `hourlyRate` se persiste como SNAPSHOT al cerrar el timer (o al
//      crear el entry manual). Esto evita que cambios futuros de tarifa
//      reescriban la historia financiera.
//   2. `durationMinutes` es 0 mientras el timer corre y se calcula al
//      hacer stop. Mantenerlo materializado hace baratos los reportes de
//      timesheet semanal sin necesidad de calcular `endedAt - startedAt`
//      en cada query.
//   3. `cost` es nullable: un entry sin tarifa vigente no rompe el flujo
//      (sólo no contribuye a EVM). Operaciones administrativas pueden
//      backfillear costos cuando se asigne tarifa retroactiva.
// ─────────────────────────────────────────────────────────────

model TimeEntry {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  endedAt         DateTime? // null mientras el timer corre
  durationMinutes Int       @default(0) // 0 mientras corre; calculado al cerrar
  description     String?
  hourlyRate      Decimal?  @db.Decimal(10, 2) // snapshot al cerrar
  cost            Decimal?  @db.Decimal(12, 2) // duration * rate
  createdAt       DateTime  @default(now())

  @@index([userId, startedAt(sort: Desc)])
  @@index([taskId, startedAt(sort: Desc)])
}

// Tarifa horaria de un usuario, válida en un rango de fechas.
// `validUntil = null` indica tarifa vigente. Históricamente conservamos
// los rangos cerrados para auditoría y para snapshot retroactivo.
model UserHourlyRate {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rate       Decimal   @db.Decimal(10, 2)
  validFrom  DateTime
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, validFrom])
}

// Módulo Custom Fields (Ola P1 · Equipo 3)
//
// Permite que cada gerencia/proyecto defina campos personalizados sobre
// `Task` (texto, número, fecha, select, multi-select, booleano, URL).
// Cada `CustomFieldDef` pertenece a un único proyecto; los valores
// (`CustomFieldValue`) están unidos a la tupla (definición, tarea) y
// cascadean al borrarse la definición o la tarea.
// ─────────────────────────────────────────────────────────────

model CustomFieldDef {
  id           String          @id @default(uuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Slug estable usado en API/exports (ej. "cliente_codigo"); único por
  // proyecto. La label es la versión human-readable mostrada en la UI.
  key          String
  label        String
  type         CustomFieldType
  required     Boolean         @default(false)
  defaultValue Json?
  // Para SELECT/MULTI_SELECT, array de `{ value, label }` validado en el
  // server action. Para otros tipos debe ser `null`.
  options      Json?
  // Orden visual configurable; permite reordenar con drag-handle sin
  // reescribir todos los registros (esquema fractional indexing).
  position     Float           @default(1)
  createdAt    DateTime        @default(now())

  values CustomFieldValue[]

  @@unique([projectId, key])
  @@index([projectId, position])
}

model CustomFieldValue {
  id      String         @id @default(uuid())
  fieldId String
  field   CustomFieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  taskId  String
  task    Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Valor serializado en JSON; el shape concreto depende de `field.type`
  // (string | number | ISO date | boolean | string | string[] | url).
  // La validación se centraliza en `setTaskFieldValue`.
  value   Json

  @@unique([fieldId, taskId])
  @@index([taskId])
}

// Módulo Centro de notificaciones (Ola P1 · HU-N1.x)
// ─────────────────────────────────────────────────────────────

// Notificación in-app dirigida a un usuario. Contraparte canal-app del
// email de mención que ya despacha `sendMentionNotification`.
//
// Reglas:
//   - `link` es relativo (ej. "/gantt?taskId=xxx"); el cliente lo abre con
//     <Link href>.
//   - `data` está reservado para metadatos extra opcionales (counts del
//     import, version de la baseline, etc.). Mantener el shape pequeño:
//     UI no debería depender de campos profundos.
//   - Sin `updatedAt`: el único mutable es `readAt` y se actualiza con
//     `markNotificationRead`/`markAllNotificationsRead`.
//   - Índices: la consulta por defecto es `userId, createdAt desc` y el
//     count de no-leídas filtra por `userId, readAt is null`.
model Notification {
  id     String           @id @default(uuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType
  title  String
  body   String?
  link   String? // URL relativa para navegar (ej. "/gantt?taskId=xxx")
  data   Json? // metadata extra (count, version, taskId…)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
}

// Preferencias por usuario para canales de notificación. En P1 los toggles
// in-app están siempre activos (no se exponen aquí); solo controlamos el
// canal email. `emailDigest` queda reservado para Ola P2 (digest diario).
model NotificationPreference {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailMentions    Boolean @default(true)
  emailAssignments Boolean @default(true)
  emailDigest      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Módulo Vistas Guardadas (Ola P2 · Equipo P2-1)
//
// Persistencia de configuraciones de filtros + grouping + columnas para
// equiparar paridad con ClickUp. Cada vista pertenece a un usuario y a una
// superficie (LIST/KANBAN/GANTT/CALENDAR/TABLE). `isShared=true` permite
// que la vista sea visible para todos los users del proyecto/org (la
// permission real se verifica en el server action vía requireUser).
// ─────────────────────────────────────────────────────────────

model SavedView {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  surface     ViewSurface
  // Estructura serializada de TaskFilters (zod-validada en server action).
  filters     Json
  // null | 'assignee' | 'sprint' | 'phase' | 'status' | 'tags' | 'priority' |
  // 'custom_field:<id>'. Validado contra GROUPING_KEYS en runtime.
  grouping    String?
  // { field, direction: 'asc' | 'desc' } opcional.
  sorting     Json?
  // visibility/order de columnas (para Table). Shape libre validado en cliente.
  columnPrefs Json?
  // true ⇒ visible para todos los users (lectura compartida; la edición
  // sigue restringida al owner).
  isShared    Boolean     @default(false)
  // 1 default por usuario por surface. Mantenemos la unicidad en código
  // (setDefaultView lo desmarca antes de marcar) para evitar migraciones
  // condicionales con WHERE en Postgres.
  isDefault   Boolean     @default(false)
  // Fractional indexing para reordenar sin reescribir todos los registros.
  position    Float       @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, surface])
  @@index([surface, isShared])
}

// Módulo Templates + Recurrencia (Ola P2 · Equipo P2-3)
//
// Permite (1) guardar plantillas reutilizables de tasks y (2) configurar
// reglas de recurrencia inspiradas en iCalendar RRULE para generar tasks
// periódicamente vía cron / Server Action `scheduleAll`.
//
// Decisiones documentadas:
//   D-RT-1: `taskShape` se persiste como JSON snapshot (no FK al Task que
//           sirvió de origen) para que renombrar/borrar la task fuente
//           no rompa el template.
//   D-RT-2: Un template puede ser global (`projectId = null`) o per-project;
//           los globales sirven a toda la organización (ej. plantillas
//           ITIL estándar).
//   D-RT-3: `byweekday` y `bymonthday` se modelan como `Int[]` —
//           Postgres soporta arrays nativos y Prisma los expone como
//           `number[]`. Bitmask Lun=0..Dom=6 (ISO weekday - 1).
//   D-RT-4: `lastGeneratedAt` se actualiza por el scheduler tras cada
//           materialización exitosa; combinado con la `@@unique` en Task
//           (`recurrenceRuleId, occurrenceDate`) garantiza idempotencia.
// ─────────────────────────────────────────────────────────────

model TaskTemplate {
  id          String  @id @default(uuid())
  name        String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Snapshot inmutable del task: { title, description, type, priority,
  // durationDays, tags[], referenceUrl, isMilestone, ... }. Validado por
  // zod en el server action al crear/actualizar.
  taskShape Json

  createdById String
  createdBy   User   @relation("TaskTemplateAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  // Cuando true, el template aparece en la lista de todos los proyectos
  // del usuario. Independiente de `projectId`: un template global
  // (`projectId = null`) puede aún no estar compartido si lo usa un solo
  // gerente.
  isShared Boolean @default(false)

  recurrences RecurrenceRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([createdById])
}

model RecurrenceRule {
  id         String       @id @default(uuid())
  templateId String
  template   TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  frequency RecurrenceFreq
  // Cada N freqs (ej. interval=2 + WEEKLY = "cada 2 semanas").
  interval  Int            @default(1)

  // ISO weekday - 1 (Lun=0..Dom=6). Vacío = todos los días de la semana.
  byweekday  Int[] @default([])
  // Día del mes 1..31. Vacío = el día derivado de `startDate`.
  bymonthday Int[] @default([])

  startDate DateTime
  endDate   DateTime?
  // Máximo de ocurrencias absolutas (count + endDate son excluyentes en
  // semántica RRULE; aquí permitimos ambos pero `count` siempre gana).
  count     Int?

  generatedTasks  Task[]    @relation("RecurringTaskInstances")
  lastGeneratedAt DateTime?
  active          Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, lastGeneratedAt])
  @@index([templateId])
}

// Módulo Goals / OKRs (Ola P2 · Equipo P2-4)
//
// Representa Objectives + Key Results al estilo OKR clásico:
//   - Goal = Objective: meta cualitativa de un ciclo (Q/H/Y), opcionalmente
//     anclada a un proyecto. Soporta jerarquía (sub-goals) vía `parentId`.
//   - KeyResult: métrica medible que contribuye a un Goal. Cuatro tipos
//     (PERCENT/NUMERIC/BOOLEAN/TASKS_COMPLETED). Para TASKS_COMPLETED el
//     `currentValue` es porcentaje (0-100) recalculado al completar tasks
//     vinculadas (`linkedTasks`).
// ─────────────────────────────────────────────────────────────

model Goal {
  id          String  @id @default(uuid())
  title       String
  description String?

  // Owner principal del Objective. Restringimos a la User table (no SetNull):
  // un OKR sin owner pierde sentido; si se elimina el usuario el caller debe
  // reasignar antes (validado vía server action / trigger UI).
  ownerId String
  owner   User   @relation("GoalOwner", fields: [ownerId], references: [id])

  // Proyecto opcional al que se ancla el Objective (Goals corporativos
  // pueden no tener proyecto). `SetNull` preserva histórico al borrar el
  // proyecto.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  status GoalStatus @default(ON_TRACK)

  // Etiqueta libre del ciclo OKR: "Q1-2026", "H1-2026", "Y2026". Se valida
  // con regex en el server action (`isValidCycle`).
  cycle String

  // Ventana temporal del Objective. Permite calcular daysElapsed/totalDays
  // para `classifyGoalStatus`.
  startDate DateTime
  endDate   DateTime

  // Jerarquía Goal → sub-Goals (Company → Team → Personal). `SetNull` al
  // borrar el padre evita perder los hijos: quedan huérfanos pero
  // accesibles. La UI permite re-anclar.
  parentId String?
  parent   Goal?   @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Goal[]  @relation("GoalHierarchy")

  // Resultados clave del Objective. Cascade: borrar el Goal borra todos
  // sus KRs (no tiene sentido un KR huérfano).
  keyResults KeyResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Patrones de query del dashboard:
  //   - "todos los goals de Edwin en Q1-2026" → (ownerId, cycle).
  //   - "todos los goals del proyecto X en H1-2026" → (projectId, cycle).
  @@index([ownerId, cycle])
  @@index([projectId, cycle])
  @@index([parentId])
}

model KeyResult {
  id String @id @default(uuid())

  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  title       String
  metric      KeyResultMetric
  // Valor objetivo. Para PERCENT y TASKS_COMPLETED suele ser 100; para
  // NUMERIC depende de unit; para BOOLEAN es 1.
  targetValue Float
  // Valor actual. Para TASKS_COMPLETED se recalcula automáticamente al
  // completar tareas vinculadas.
  currentValue Float @default(0)
  // Unidad opcional human-readable (USD, %, users…). Solo se muestra en
  // la UI; no afecta cálculo.
  unit     String?
  // Orden visual del KR dentro del Goal (fractional indexing).
  position Float   @default(1)

  // Tasks vinculadas — solo relevante cuando `metric=TASKS_COMPLETED`. M:N
  // implícita ("_KeyResultTasks"). El recompute consulta status=DONE.
  linkedTasks Task[] @relation("KeyResultTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId, position])
}

// ─────────────────────────────────────────────────────────────
// Módulo Integraciones externas (Ola P4 · Equipo P4-5)
//
// Soporta tres tipos de integración:
//   - SLACK : webhook outbound a un canal Slack (Block Kit).
//   - TEAMS : webhook outbound a un canal MS Teams (Adaptive Card v1.4).
//   - GITHUB: vincula tareas a issues/PRs (no webhooks inbound en P4).
//
// `config` es JSON libre validado en server action según el `type` (zod
// dispatch). Para SLACK/TEAMS contiene `{ webhookUrl: string, channel? }`;
// para GITHUB contiene `{ defaultRepo?: string, token? }` (token opcional
// para futuras llamadas autenticadas — en P4 sólo guardamos referencia).
//
// `projectId` opcional: integraciones globales del workspace viven con
// `projectId = null` y se disparan para todos los proyectos. Cuando hay
// integración específica del proyecto, ésta se prefiere sobre la global.
// ─────────────────────────────────────────────────────────────

enum IntegrationType {
  SLACK
  TEAMS
  GITHUB
}

model Integration {
  id   String          @id @default(uuid())
  type IntegrationType

  // Etiqueta visible en la UI (ej. "Slack #devops", "Repo principal").
  // Permite distinguir varias integraciones del mismo tipo.
  name String

  // Configuración por tipo. Validada en `validateIntegrationConfig` del
  // server action. Mantener pequeño y sin secretos largos (tokens van
  // cifrados en una iteración futura — P4 los guarda en claro asumiendo
  // que el webhook URL ya es el secreto).
  config Json

  // Toggle global. Cuando `false` los dispatchers son no-op silencioso.
  enabled Boolean @default(true)

  // Anclaje opcional a proyecto. NULL = integración global del workspace.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, enabled])
  @@index([projectId])
}

// Vínculo de una `Task` a un issue/PR concreto de GitHub. No hay webhooks
// inbound en P4 — esta tabla solo guarda la referencia para poder abrir el
// issue desde el TaskDrawer. `repoFullName` es "owner/repo" (validado con
// regex en server action). `issueNumber` es entero positivo; aplica tanto a
// issues como a PRs (GitHub comparte el namespace numérico).
model TaskGitHubLink {
  id String @id @default(uuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // "owner/repo" (ej. "alejandroeml-su/FollowupGantt").
  repoFullName String

  // Número del issue/PR (positivo). GitHub usa el mismo namespace para
  // ambos, pero etiquetamos con `kind` para que la UI muestre el icono
  // correcto sin tener que llamar a la API.
  issueNumber Int

  // "ISSUE" | "PR". String libre (no enum) para no requerir migración si
  // GitHub introduce nuevos tipos. Validado vs un set conocido en zod.
  kind String @default("ISSUE")

  createdAt DateTime @default(now())

  // Una tarea no puede vincular dos veces el mismo issue del mismo repo.
  @@unique([taskId, repoFullName, issueNumber])
  @@index([taskId])
  @@index([repoFullName, issueNumber])
}
