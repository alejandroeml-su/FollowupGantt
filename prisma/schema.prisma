generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// ENUMERADORES (Tipos definidos)
// ---------------------------------------------------------

enum TaskType {
  AGILE_STORY
  PMI_TASK
  ITIL_TICKET
}

enum DependencyType {
  FINISH_TO_START // FS
  START_TO_START // SS
  FINISH_TO_FINISH // FF
  START_TO_FINISH // SF
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

/// Wave P14 — Metodología de gestión del proyecto.
/// SCRUM: ágil puro · PMI: plan-driven (PMBOK) · HYBRID: ambos.
enum ProjectMethodology {
  SCRUM
  PMI
  HYBRID
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// Tipos soportados por el módulo de Custom Fields (Ola P1, Equipo 3).
// Cada definición de campo tiene un tipo fijo; la validación zod se
// despacha por este enum en el server action.
enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  URL
}

// Ola P1 · Centro de notificaciones in-app.
// Añadido cuando todavía no existe sesión real: el `userId` lo provee el
// caller (Sidebar hardcodea SUPER_ADMIN; futuro hook de auth).
enum NotificationType {
  MENTION
  TASK_ASSIGNED
  COMMENT_REPLY
  BASELINE_CAPTURED
  DEPENDENCY_VIOLATION
  IMPORT_COMPLETED
  /// Wave P18-B — notificación generada por una AutomationRule.
  AUTOMATION
}

// Ola P2 · Equipo P2-1 — Vistas guardadas multi-surface.
// Cada SavedView fija una "superficie" (qué tablero la consume) para que
// los filtros, grouping y columnPrefs sean coherentes con la UI destino.
enum ViewSurface {
  LIST
  KANBAN
  GANTT
  CALENDAR
  TABLE
}

// Ola P2 · Equipo P2-3 — Recurrencia de tareas (subset iCalendar RRULE).
// Frecuencia base que combinada con `interval`, `byweekday` y `bymonthday`
// describe patrones tipo "cada 2 semanas, lun y mié" o "el día 15 de cada mes".
enum RecurrenceFreq {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

// Ola P2 · Equipo P2-4 · Goals & OKRs.
// Estado del Objective: ON_TRACK / AT_RISK / OFF_TRACK derivado de la
// función `classifyGoalStatus` (heurística progress vs tiempo transcurrido).
// COMPLETED / CANCELLED se setean manualmente desde la UI.
enum GoalStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
  CANCELLED
}

// Ola P5 · Equipo P5-1 · Whiteboards estilo Miro.
// Tipos de elementos soportados por el canvas. STICKY = nota adhesiva con
// color y texto; SHAPE = rectángulo/círculo (data.shape define la variante);
// CONNECTOR = línea con anchors; TEXT = caja de texto sin fondo; IMAGE =
// reservado para iteraciones futuras (drag&drop de imágenes).
enum WhiteboardElementType {
  STICKY
  SHAPE
  CONNECTOR
  TEXT
  IMAGE
}

// Tipo de métrica de un Key Result. Define cómo se calcula `currentValue`
// y se renderiza el progreso:
//   - PERCENT: 0-100, manual.
//   - NUMERIC: cualquier número con `unit` (USD, users, …); progress =
//     currentValue / targetValue.
//   - BOOLEAN: true/false (1 = done, 0 = pending).
//   - TASKS_COMPLETED: progress derivado de tasks vinculadas.
// Ola P4 · Equipo P4-1 — Multi-tenancy / Workspaces.
// Plan comercial del Workspace: condiciona límites (proyectos, miembros)
// que pueden añadirse en P4.x. En el MVP de tenancy guardamos sólo el
// enum; los límites por plan se aplicarán en server actions cuando se
// monetice el producto.
enum WorkspacePlan {
  FREE
  PRO
  ENTERPRISE
}

// Rol del miembro DENTRO del workspace (independiente del Role global
// SUPER_ADMIN/ADMIN/AGENTE). Un usuario puede ser OWNER en su workspace
// personal y MEMBER en el workspace corporativo.
//   - OWNER  : único e inamovible — sólo se puede transferir.
//   - ADMIN  : invita y elimina miembros, edita configuración del WS.
//   - MEMBER : acceso al contenido del workspace, sin gestión de miembros.
enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum KeyResultMetric {
  PERCENT
  NUMERIC
  BOOLEAN
  TASKS_COMPLETED
}

// Ola P5 · Equipo P5-4 · AI Insights heurísticos.
// Tipos de insight generados sin LLM externo en este sprint:
//   - CATEGORIZATION: sugerencia de TaskType + tags + assignee derivada
//     de keywords/menciones del título/descripción.
//   - DELAY_RISK:    score 0-1 derivado de progress vs tiempo elapsed,
//     historial del assignee, tamaño y predecesoras pendientes.
//   - NEXT_ACTION:   sugerencia accionable a nivel proyecto (ej. "X
//     tareas en CP sin assignee").
enum InsightKind {
  CATEGORIZATION
  DELAY_RISK
  NEXT_ACTION
}

// ---------------------------------------------------------
// ENTIDADES PRINCIPALES
// ---------------------------------------------------------

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique

  // Wave C-debt-1 · Avatar URL (o data-URI). Opcional porque la mayoría de
  // usuarios no sube imagen al inicio. Se publica vía
  // `getCurrentUserPresence` (Realtime/Presence — wave P6 · B1) y se usará
  // a futuro en avatares del menú/comentarios. NUNCA exponer junto con
  // PII como email/roles fuera del canal Presence.
  image String?

  // ── Auth (P1 MVP) ─────────────────────────────────────────────
  // Hash PBKDF2 + salt (formato `pbkdf2$<iter>$<saltB64>$<hashB64>`).
  // Nullable porque puede provenir de SSO en futuras iteraciones.
  password      String?
  emailVerified DateTime?

  // ── Auth (P3) · 2FA TOTP opcional (RFC 6238) ─────────────────
  // Secret base32 cifrado at-rest cuando se acuerde KMS; por ahora
  // se guarda raw porque sólo super-admin lo activa y la BD ya está
  // protegida con RLS + secret manager. NULL → 2FA deshabilitado.
  twoFactorSecret String?

  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]

  // Roles y Permisos
  roles UserRole[]

  // Equipos
  teams TeamMember[]

  // Asignaciones a Proyectos (para restringir edición)
  projectAssignments ProjectAssignment[]

  // Relaciones
  managedProjects     Project[]          @relation("ProjectManager")
  // Wave P9 · Agile Maturity (HU-9.1) — Epics owned por este user.
  ownedEpics          Epic[]             @relation("EpicOwner")
  // Wave P9 · Agile Maturity (HU-9.4) — Releases owned por este user.
  ownedReleases       Release[]          @relation("ReleaseOwner")
  // Wave P9 R2 (HU-9.9) — Retrospectivas que este user facilitó.
  facilitatedRetros   Retrospective[]    @relation("RetroFacilitator")
  tasks               Task[]             @relation("TaskAssignee")
  taskCollaborations  TaskCollaborator[] @relation("TaskCollaborator")
  comments            Comment[]          @relation("CommentAuthor")
  history             TaskHistory[]
  attachments         Attachment[]
  // Wave P8-4 — Relación explícita para `Attachment.uploadedById` (alias
  // semántico de `userId` durante migración). Inversa nombrada porque la
  // relación con `userId` ya ocupa la default.
  uploadedAttachments Attachment[]       @relation("AttachmentUploadedBy")
  mindMaps            MindMap[]          @relation("MindMapOwner")

  // Time Tracking (Ola P1, Equipo 4) — un usuario tiene múltiples entries
  // y un historial de tarifas horarias (efectivas por rango de fechas).
  timeEntries TimeEntry[]
  hourlyRates UserHourlyRate[]

  // Ola P1 · Centro de notificaciones in-app (HU-N1.x).
  notifications          Notification[]
  notificationPreference NotificationPreference?

  // Wave P6 · Equipo A4 · Web Push API — suscripciones del navegador
  // (pushManager.subscribe) por device. CASCADE al borrar usuario.
  pushSubscriptions PushSubscription[]

  // Ola P2 · Vistas guardadas (Equipo P2-1).
  savedViews SavedView[]

  // Ola P2 · Templates creados por el usuario (Equipo P2-3).
  taskTemplates TaskTemplate[] @relation("TaskTemplateAuthor")

  // Ola P2 · Equipo P2-4 · Goals & OKRs.
  // Objetivos donde este usuario figura como `owner`. La relación inversa
  // de `parentId/children` no incluye al User: es propiedad estructural del
  // Goal.
  ownedGoals Goal[] @relation("GoalOwner")

  // Ola P5 · Equipo P5-1 · Whiteboards.
  // Pizarras creadas por el usuario. `SetNull` en Whiteboard preserva el
  // tablero aunque se elimine el creador.
  createdWhiteboards Whiteboard[] @relation("WhiteboardCreator")

  // Ola P4 · Equipo P4-1 — Multi-tenancy / Workspaces.
  // Un usuario puede ser dueño de varios workspaces (ej. personal + del
  // cliente A) y miembro de muchos. Las invitaciones que el usuario envía
  // se guardan en `WorkspaceInvitation.invitedById` para auditoría.
  ownedWorkspaces      Workspace[]           @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[]
  sentInvitations      WorkspaceInvitation[] @relation("InvitationInviter")

  // Ola P4 · Equipo P4-2 · API REST pública + Webhooks.
  // Tokens y webhooks pertenecen al usuario que los creó; cascadean al borrar.
  apiTokens ApiToken[]
  webhooks  Webhook[]

  // Wave P17-B · Equipo B — API pública v2 + Webhooks v2 (auditoría de creación;
  // las credenciales pertenecen al workspace, NO al usuario, así que aquí
  // mantenemos la relación con SetNull para preservar histórico).
  createdApiKeys              ApiKey[]              @relation("ApiKeyCreator")
  createdWebhookSubscriptions WebhookSubscription[] @relation("WebhookSubscriptionCreator")

  // Ola P2 · Equipo P2-5 — Docs / Wikis. Un usuario puede ser autor original
  // de un doc, último editor (último que pasó por `updateDoc`) y autor de
  // versiones intermedias del histórico.
  authoredDocs   Doc[]        @relation("DocAuthor")
  lastEditedDocs Doc[]        @relation("DocLastEditor")
  docVersions    DocVersion[]

  // Ola P3 · Equipo P3-2 · Audit Log centralizado.
  // Eventos de auditoría donde este usuario figura como `actor`. La relación
  // es onDelete: SetNull en `AuditEvent.actor` para conservar el log aún
  // cuando el usuario sea borrado (compliance ITIL/SOC2: el evento debe
  // sobrevivir al actor que lo originó).
  auditEvents AuditEvent[] @relation("AuditEventActor")

  // Ola P8 · Equipo P8-1 · Resource Management.
  // Habilidades del usuario con nivel 1-5 (matriz de skills). Se usa para
  // filtrar usuarios "disponibles" en TaskForm y para el algoritmo de
  // rebalanceo (un task se puede reasignar a otro user con la misma skill
  // y nivel >= al requerido). Cascade: al borrar el usuario se borran sus
  // entradas en la matriz.
  userSkills UserSkill[]

  // Wave P8 · Equipo P8-2 · Risk Register + Monte Carlo.
  // Riesgos de los que este usuario figura como owner / responsable de la
  // mitigación. `SetNull` en Risk.ownerId preserva el riesgo aunque el
  // usuario sea borrado (compliance PMI: el risk register debe sobrevivir
  // a la rotación de su dueño original).
  risksOwned Risk[] @relation("RiskOwner")

  // Wave R-360 — Acciones correctivas de riesgos asignadas a este usuario.
  // `SetNull` en RiskAction.ownerId preserva el plan aunque cambie de dueño.
  riskActionsOwned RiskAction[] @relation("RiskActionOwner")

  // Wave P18-A · Quality Inspections + Defect Tracking
  inspectionsAsInspector QualityInspection[] @relation("InspectionInspector")
  defectsOwned           Defect[]             @relation("DefectOwner")
  defectsReported        Defect[]             @relation("DefectReporter")

  // Wave P8 · Equipo P8-5 — Calendar sync (Google + Microsoft + ICS).
  // Conexiones por provider (Google Calendar, MS Graph, ICS feed). Un
  // usuario puede tener hasta una conexión por provider (constraint
  // `@@unique([userId, provider])` en CalendarConnection). Cascade al
  // borrar el usuario para no dejar tokens huérfanos.
  calendarConnections CalendarConnection[]

  // Ola P8 · Equipo P8-3 · Cost Management.
  // Gastos sometidos por este usuario y aprobados por este usuario. Los
  // gastos sometidos usan `Restrict` (no perdemos historial financiero al
  // borrar un usuario), las aprobaciones usan `SetNull` (preservamos el
  // gasto aunque el aprobador desaparezca).
  submittedExpenses Expense[] @relation("ExpenseSubmitter")
  approvedExpenses  Expense[] @relation("ExpenseApprover")

  // Wave P10 (HU-10.2) — Disponibilidad individual (vacaciones, días reducidos).
  // Cascade al borrar usuario.
  availabilities UserAvailability[]

  // Wave P10 (HU-10.7) — Snapshots semanales de allocation cross-project.
  allocationSnapshots ResourceAllocationSnapshot[]

  // Wave P11-PMI (HU-12.3) — Change Requests
  changeRequestsRequested ChangeRequest[] @relation("ChangeRequestRequester")
  changeRequestsApproved  ChangeRequest[] @relation("ChangeRequestApprover")

  /// Wave P13 (RBAC visibilidad por gerencia) — Gerencia que el usuario
  /// gestiona si su rol es GERENTE_AREA. Para roles superiores
  /// (GERENCIA_GENERAL/ADMIN/SUPER_ADMIN) se ignora; para USER también
  /// es null. La visibilidad por gerencia se resuelve vía
  /// `Project.area.gerenciaId == user.gerenciaId`.
  gerenciaId String?
  gerencia   Gerencia? @relation("GerenteArea", fields: [gerenciaId], references: [id], onDelete: SetNull)

  /// Soft delete · darse de baja sin perder historial (audit/sesiones
  /// pasadas/tareas asignadas). NULL = activo, NOT NULL = inactivo
  /// desde esa fecha. `signIn()` rechaza usuarios con archivedAt set.
  archivedAt DateTime?

  // Wave P12 (Scrum 100%) — Impediments & Daily Scrum & Improvements
  impedimentsRaised  Impediment[]      @relation("ImpedimentRaiser")
  impedimentsOwned   Impediment[]      @relation("ImpedimentOwner")
  facilitatedDailies DailyScrum[]      @relation("DailyScrumFacilitator")
  ownedImprovements  ImprovementItem[] @relation("ImprovementOwner")

  // Wave P12 (PMI 100%) — Lessons Learned
  capturedLessons LessonLearned[] @relation("LessonCapturer")

  // Wave P17-C — Plantillas globales creadas por este usuario (SUPER_ADMIN).
  createdGlobalTemplates GlobalTemplate[] @relation("GlobalTemplateCreator")

  // Wave P19-D — Strategist insights cross-project que este usuario ha
  // reconocido (ACKNOWLEDGED). SetNull en `BrainStrategistInsight.ackById`
  // preserva el insight aunque el actor sea eliminado.
  strategistInsightsAcked BrainStrategistInsight[] @relation("StrategistInsightAck")

  /// R3.0 Fase 2 · SSO/SAML — Vínculos a IdP externos (un user puede
  /// estar federado por varios providers, ej. SAML corporativo + Google).
  /// Cascade al borrar usuario para no dejar vínculos huérfanos.
  ssoLinks SsoUserLink[]

  /// Wave P20-C · Brain Auto-Pilot — runs aplicadas por este usuario.
  /// SetNull en `AutoPilotRun.appliedById` preserva el run aunque el
  /// actor sea eliminado (mismo criterio que `BrainStrategistInsight.ackBy`).
  autoPilotRunsApplied AutoPilotRun[] @relation("AutoPilotRunAppliedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Auth: tablas estándar Auth.js / NextAuth (P1 MVP) ─────────────
// Aunque hoy implementamos credentials con sesión propia (cookie firmada
// + tabla Session), mantenemos el shape de Account compatible para
// migrar a NextAuth + Prisma adapter sin romper datos cuando se agreguen
// providers SSO (Google/Microsoft) en una iteración posterior.

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  // ── Auth (P3) · Session management UI ────────────────────────
  // Metadata para listar y revocar dispositivos activos. Capturada
  // en el momento del login (oauth callback o credentials). Todos
  // nullable para no romper sesiones legacy creadas en P1.
  userAgent  String?
  ipAddress  String?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ── Auth (P3) · Password reset flow ─────────────────────────────
// Token hasheado (SHA-256 hex) con TTL 1h. Se hashea para que un
// dump de BD no permita usar el token directamente — el correo
// envía el token plano y aquí guardamos sólo el digest.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique // AGENTE, ADMIN, SUPER_ADMIN
  description String?
  permissions Json? // Ejemplo: { "allowedViews": ["list", "kanban", "gantt"] }

  users UserRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Team {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  members  TeamMember[]
  /// Wave P13 — Proyectos asignados al equipo. Cualquier miembro activo
  /// (TeamMember) gana visibilidad sobre estos proyectos.
  projects TeamProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  teamId String
  userId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
}

/// Wave P13 (RBAC visibilidad) — Asignación de equipos a proyectos.
/// Un proyecto puede tener N equipos asignados; un equipo puede trabajar
/// en N proyectos. Los miembros del equipo heredan visibilidad sobre los
/// proyectos asignados (regla del Usuario estándar).
model TeamProject {
  teamId    String
  projectId String
  team      Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([teamId, projectId])
  @@index([projectId])
}

model ProjectAssignment {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

// Módulo de Estructura Organizacional
model Gerencia {
  id          String  @id @default(uuid())
  name        String  @unique // Ejemplo: "OPERACIONES", "FINANZAS"
  description String?

  areas    Area[]
  /// Wave P13 — Gerentes de área que tienen visibilidad sobre todos
  /// los proyectos de esta gerencia.
  gerentes User[] @relation("GerenteArea")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Area {
  id          String  @id @default(uuid())
  name        String // Ejemplo: "Desarrollo", "Infraestructura"
  description String?

  // Relación con Gerencia (obligatoria)
  gerenciaId String
  gerencia   Gerencia @relation(fields: [gerenciaId], references: [id], onDelete: Cascade)

  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)

  /// Wave P14 — Metodología que rige la gestión del proyecto.
  /// SCRUM: ágil puro · PMI: PMBOK plan-driven · HYBRID: combinación.
  /// Determina qué vistas/artefactos exhibir como prominentes.
  methodology ProjectMethodology @default(HYBRID)

  // Ola P4 · Equipo P4-1 — Multi-tenancy / Workspaces.
  // Opcional inicial: las server actions usan `getDefaultWorkspaceForUser`
  // para inferir el WS por defecto si no viene del cliente. En migración
  // futura se promoverá a NOT NULL una vez backfilled todos los proyectos.
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  // Área / Gerencia
  areaId String?
  area   Area?   @relation(fields: [areaId], references: [id])

  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  // KPIs financieros y de cronograma (EVM - Earned Value Management)
  // Se pueden guardar calculados o dejarlos para consulta dinámica
  cpi Float? // Cost Performance Index
  spi Float? // Schedule Performance Index

  // Calendario laboral aplicable al proyecto (Ola P1.5).
  // Si NULL → CPM y workload usan días corridos (legacy).
  calendarId String?
  calendar   WorkCalendar? @relation(fields: [calendarId], references: [id])

  /// Wave P9 R2 (HU-9.8) — Definition of Ready & Done por proyecto.
  /// Shape: `string[]` (lista ordenada). Validación SOFT al mover
  /// status (toast informativo, no bloqueante; distinto del guard
  /// HARD de CAs HU-9.3).
  dorTemplate Json?
  dodTemplate Json?

  /// Wave P11-Scrum (HU-11.1) — Product Goal a nivel producto.
  /// Shape: `{ statement: string, successMetrics: string[],
  /// targetDate: string|null, lastReviewedAt: string|null }`.
  /// Commitment formal del Scrum Guide 2020 — define el "para qué"
  /// del Product Backlog. El Product Owner es responsable.
  productGoal Json?

  /// Wave P11-PMI (HU-12.1) — Project Charter formal PMBOK.
  /// Shape: `{ vision: string, businessJustification: string,
  /// successCriteria: string[], milestones: [{name, targetDate}],
  /// approvedAt: string|null, approvedBy: string|null,
  /// version: number }`.
  /// Artefacto que autoriza formalmente el inicio del proyecto.
  charter Json?

  /// Wave P11-PMI — Stakeholder Register + Change Request relations.
  stakeholders   Stakeholder[]
  changeRequests ChangeRequest[]
  contracts      Contract[]
  purchaseOrders PurchaseOrder[]

  /// Wave P12 (Scrum 100% · DoD HARD) — Cuando true, mover una tarea a DONE
  /// requiere checklist DoD completo (no warning). Default false (mantiene
  /// comportamiento legacy SOFT toast informativo).
  dodHardEnforce Boolean @default(false)

  /// Wave P12 (PMI 100%) — Plan formal de comunicaciones del proyecto.
  /// Shape: { items: [{ id, audience, frequency, channel, owner,
  /// nextDelivery, notes }], updatedAt }
  /// Validador en `lib/communications/types.ts`.
  communicationsPlan Json?

  /// Wave P12 — Lessons Learned + EVM snapshots + Improvement Items relations.
  lessonsLearned   LessonLearned[]
  evmSnapshots     EVMSnapshot[]
  /// Wave P15 — Insights generados por Avante Brain AI.
  brainInsights    BrainInsight[]
  improvementItems ImprovementItem[]

  // Relaciones
  phases          Phase[]
  sprints         Sprint[]
  columns         BoardColumn[]
  tasks           Task[]
  baselines       Baseline[]
  assignments     ProjectAssignment[]
  /// Wave P13 (RBAC) — Equipos con visibilidad sobre el proyecto.
  teamProjects    TeamProject[]
  mindMaps        MindMap[]
  // Wave P9 · Agile Maturity (HU-9.1, HU-9.2). Epic agrupa stories/tasks
  // bajo iniciativas reconocibles visualmente sin abusar del nesting de
  // subtask. Relación 1-N con Task vía `Task.epicId`.
  epics           Epic[]
  // Wave P9 (HU-9.4) — Releases versionadas del proyecto.
  releases        Release[]
  // Custom Fields configurables por proyecto (Ola P1, Equipo 3).
  customFieldDefs CustomFieldDef[]

  // Templates por proyecto (Ola P2, Equipo P2-3). Un template puede ser
  // global (`projectId = null`) o per-project; los globales se reutilizan
  // entre todos los proyectos y los per-project sólo aparecen en su lista.
  taskTemplates TaskTemplate[]

  // Ola P2 · Equipo P2-4 · Goals & OKRs.
  // Objetivos asociados al proyecto. `onDelete: SetNull` en Goal preserva
  // los OKRs históricos aunque se elimine el proyecto.
  goals Goal[]

  // Ola P5 · Equipo P5-5 · Public Forms + Automation engine.
  publicForms     PublicForm[]
  automationRules AutomationRule[]

  // Ola P5 · Equipo P5-1 · Whiteboards.
  // Pizarras vinculadas al proyecto (opcional). `SetNull` en Whiteboard
  // preserva la pizarra aunque se elimine el proyecto.
  whiteboards Whiteboard[]

  // Ola P2 · Equipo P2-5 · Docs / Wikis.
  // Documentos vinculados al proyecto. `SetNull` en Doc.projectId conserva
  // el doc histórico aunque se elimine el proyecto (queda "huérfano" pero
  // accesible).
  docs Doc[]

  // Ola P4 · Equipo P4-5 · Integraciones externas.
  // Integraciones (Slack/Teams/GitHub) ancladas a este proyecto. `projectId`
  // es opcional en `Integration`: las integraciones globales del workspace
  // viven con `projectId = null` y aplican a todos los proyectos.
  integrations Integration[]

  // Wave P8 · Equipo P8-2 · Risk Register. CASCADE al borrar proyecto:
  // los riesgos son metadata viva del proyecto y no deben sobrevivir a su
  // borrado (a diferencia de baselines o docs).
  risks Risk[]

  // Wave P18-A · Quality Inspections + Defect Tracking.
  qualityInspections QualityInspection[]
  defects            Defect[]

  // Ola P8 · Equipo P8-3 · Cost Management.
  // Presupuesto base del proyecto (BAC) y moneda. Si NULL, los reportes de
  // EAC/VAC fallan-back al sum(plannedValue) de tasks. La moneda canónica
  // para reporting es USD; las conversiones usan la última `CurrencyRate`.
  budget         Decimal?  @db.Decimal(14, 2)
  budgetCurrency String?
  expenses       Expense[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
}

// Fases del Proyecto (Waterfall / PMI)
model Phase {
  id    String @id @default(uuid())
  name  String
  order Int    @default(0)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  // Ola P8 · Equipo P8-3 · Cost Management.
  // Presupuesto opcional por fase (Waterfall). Sirve para alertas de
  // overrun granular y para el chart Budget vs Actual por fase.
  budget         Decimal? @db.Decimal(14, 2)
  budgetCurrency String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Wave P9 · Agile Maturity (HU-9.1, HU-9.2)
///
/// Epic — contenedor de iniciativas grandes que agrupan múltiples
/// User Stories / Tasks bajo un mismo paraguas semántico (sin abusar
/// del nesting de subtask, que está diseñado para descomposición
/// jerárquica de trabajo, no agrupación temática).
///
/// Diferencias clave con Phase y Sprint:
///   - Phase = contenedor temporal/de fase PMBOK (Inicio/Plan/Exec/Close).
///     Lifecycle: secuencial.
///   - Sprint = contenedor de iteración Scrum (1-4 semanas).
///     Lifecycle: time-boxed.
///   - Epic = contenedor temático de feature/iniciativa.
///     Lifecycle: cross-phase, cross-sprint.
///
/// Una Task puede tener simultáneamente phaseId + sprintId + epicId
/// (los 3 son ejes ortogonales de organización).
model Epic {
  id          String  @id @default(uuid())
  name        String
  description String?

  /// Color hexadecimal para el badge visual. Default azul indigo del
  /// design system. Validado en server action a `^#[0-9a-fA-F]{6}$`.
  color String @default("#818cf8")

  /// Estado del Epic. Diferente de TaskStatus porque agrega valor
  /// estratégico (un Epic IN_PROGRESS puede tener Tasks DONE y TODO
  /// simultáneamente; el estado del Epic es manual).
  status EpicStatus @default(PLANNED)

  /// Owner del Epic (usualmente el Product Owner o líder técnico).
  /// Distinto de `assignee` de cada Task individual.
  ownerId String?
  owner   User?   @relation("EpicOwner", fields: [ownerId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Posición para drag-drop reorder (lexorank-style).
  position Int @default(0)

  /// Tasks asignadas a este Epic. ON DELETE SET NULL en Task.epicId
  /// para no perder Tasks si se borra el Epic.
  tasks Task[]

  /// Wave P9 (HU-9.4) — Releases que incluyen este Epic en su scope.
  releases ReleaseEpic[]

  /// Fechas opcionales de planificación. No afectan el cronograma del
  /// proyecto (NO se usan en CPM); son sólo informativas para el UI.
  plannedStartDate DateTime?
  plannedEndDate   DateTime?

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, archivedAt])
  @@index([projectId, status])
}

enum EpicStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELLED
}

/// Wave P9 · Agile Maturity (HU-9.4, HU-9.5)
///
/// Release — agrupa Epics o Sprints bajo una versión entregable con
/// fecha planeada. Permite comunicar a stakeholders "qué incluye v1.0
/// y cuándo sale" sin que tengan que entender el nivel Task.
///
/// Decisión arquitectura: scopeMode es exclusivo (EPIC o SPRINT) —
/// una Release agrupa N Epics O N Sprints, no mezcla. Razón: el
/// rollup de progress se calcula sobre ese eje, mezclar produce
/// ambigüedad de cómo "promediar" un Sprint y una Epic.
///
/// Lifecycle:
///   PLANNED  → released=false, plannedDate futuro
///   IN_PROGRESS → released=false, dentro de ventana scope
///   RELEASED → released=true, releasedDate setteado
///   DELAYED  → released=false, plannedDate pasado y no done
///   CANCELLED → released=false, archivedAt setteado
model Release {
  id          String  @id @default(uuid())
  name        String
  /// Versión semántica visible (ej. "1.0", "v2.5", "Q3-2026"). Free-form.
  version     String
  description String?

  /// Modo de scope. Determina qué tipo de relaciones agrupa:
  /// EPIC → ReleaseEpic[]
  /// SPRINT → ReleaseSprint[]
  scopeMode ReleaseScopeMode @default(EPIC)

  /// Fecha objetivo de release. Sirve para timeline y para calcular
  /// estado on-track / delayed.
  plannedDate DateTime

  /// Fecha real de release. NULL hasta que se marque "Released".
  releasedDate DateTime?

  ownerId String?
  owner   User?   @relation("ReleaseOwner", fields: [ownerId], references: [id])

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// M2M con Epics (sólo si scopeMode=EPIC).
  epics ReleaseEpic[]

  /// M2M con Sprints (sólo si scopeMode=SPRINT).
  sprints ReleaseSprint[]

  archivedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, archivedAt])
  @@index([projectId, plannedDate])
}

enum ReleaseScopeMode {
  EPIC
  SPRINT
}

/// Tabla join Release ↔ Epic. Se usa cuando scopeMode=EPIC.
model ReleaseEpic {
  releaseId String
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  epicId String
  epic   Epic   @relation(fields: [epicId], references: [id], onDelete: Cascade)

  /// Orden visual dentro del scope de la release (drag-drop).
  position Int @default(0)

  addedAt DateTime @default(now())

  @@id([releaseId, epicId])
  @@index([releaseId])
  @@index([epicId])
}

/// Tabla join Release ↔ Sprint. Se usa cuando scopeMode=SPRINT.
model ReleaseSprint {
  releaseId String
  release   Release @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  position Int @default(0)

  addedAt DateTime @default(now())

  @@id([releaseId, sprintId])
  @@index([releaseId])
  @@index([sprintId])
}

// Módulo Agile: Sprints y Columnas Kanban
//
// Ola P2 · Equipo P2-2 — Story Points + Velocity:
//   - `capacity` = puntos de historia comprometidos por el equipo al
//     planificar el sprint (input humano).
//   - `startedAt` / `endedAt` = timestamps reales del lifecycle (distintos
//     de `startDate`/`endDate`, que son la planificación). Se setean al
//     invocar `startSprint` / `endSprint` respectivamente.
//   - `velocityActual` = suma de `storyPoints` de tasks DONE en el sprint
//     al momento de cerrarlo. Se persiste para que el VelocityChart no
//     dependa de re-calcular sobre el grafo de tasks (que puede mutar
//     después del cierre).
model Sprint {
  id        String        @id @default(uuid())
  name      String
  goal      String?
  startDate DateTime
  endDate   DateTime
  status    ProjectStatus @default(PLANNING)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // ── Agile metrics (Ola P2) ──────────────────────────────────────
  capacity       Int?
  startedAt      DateTime?
  endedAt        DateTime?
  velocityActual Int?

  // ── Sprint Review (Wave P11-Scrum · HU-11.2) ────────────────────
  /// Timestamp de cierre del Sprint Review event. Si NULL, el Review
  /// aún no se ha realizado (incluso si el sprint ya está endedAt).
  reviewedAt  DateTime?
  /// Notas/feedback del Review por stakeholders.
  reviewNotes String?
  /// Link de demo del increment (Loom, video grabado, etc).
  demoUrl     String?

  // Ola P8 · Equipo P8-1 · Resource Management — overrides puntuales
  // de capacidad por usuario para este sprint (vacaciones, on-call,
  // compromisos paralelos). Shape esperado:
  // { [userId: string]: { dailyHours?: number, off?: string[] } }
  // Donde `off` lista días ISO (YYYY-MM-DD) sin disponibilidad y
  // `dailyHours` sobreescribe el default 8h del calendario. NULL ⇒
  // se usa la capacidad estándar del calendar.
  capacityPerUser Json?

  tasks Task[]

  /// Wave P9 (HU-9.4) — Releases que incluyen este Sprint en su scope.
  releases ReleaseSprint[]

  /// Wave P9 R2 (HU-9.9) — Retrospectivas del sprint. Un sprint puede
  /// tener N retros (típico: 1 al cerrar; opcional re-abrir si surge
  /// reflexión adicional). En la práctica la app se ancla a la última
  /// activa.
  retrospectives Retrospective[]

  /// Wave P12 (Scrum 100%) — Impediments levantados durante el sprint.
  impediments Impediment[]
  /// Wave P12 (Scrum 100%) — Sesiones de Daily Scrum (sync diaria).
  dailyScrums DailyScrum[]

  // Ola P8 · Equipo P8-3 · Cost Management.
  // Presupuesto opcional por sprint (Agile). Útil para teams con T&M /
  // contratos por iteración. Independiente del budget de phase: ambos
  // pueden coexistir en proyectos híbridos PMI/Agile.
  budget         Decimal? @db.Decimal(14, 2)
  budgetCurrency String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Wave P9 R2 (HU-9.9) — Retrospectiva de Sprint.
///
/// Captura aprendizajes del equipo en un format estructurado. Items
/// (notas, votos, action items) viven en Json para evitar tabla
/// extra — el shape lo valida `lib/retrospective/types.ts`.
///
/// Lifecycle:
///   - createdAt: cuando se inicia la retro (típicamente al cerrar el sprint).
///   - completedAt: cuando se da por cerrada (acuerdo del equipo).
///     Tras completedAt, los items quedan readonly (audit log).
///
/// Action items: cuando el equipo decide convertir un item en tarea
/// concreta, se crea una `Task` separada con type=AGILE_STORY y se
/// guarda el `taskId` en el item. Permite tracking sin re-implementar
/// task management.
model Retrospective {
  id    String  @id @default(uuid())
  title String
  /// Notas opcionales (markdown plano permitido).
  notes String?

  /// Format del retro (estructura de columnas/categorías).
  format RetrospectiveFormat @default(FOUR_LS)

  /// Items + categorías + votes + action items en Json. Shape:
  /// { categories: { [categoryId]: { label, items: RetroItem[] } } }
  /// Donde RetroItem = { id, text, votes: string[], authorId, taskId? }
  /// El validador vive en `lib/retrospective/types.ts`.
  data Json?

  facilitatorId String?
  facilitator   User?   @relation("RetroFacilitator", fields: [facilitatorId], references: [id])

  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  completedAt DateTime?

  /// Wave P12 — Improvement items derivados de esta retro (cross-sprint).
  improvementItems ImprovementItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sprintId, completedAt])
}

enum RetrospectiveFormat {
  /// 4 columnas: Liked / Lacked / Learned / Longed-for.
  FOUR_LS
  /// 3 columnas: Start / Stop / Continue.
  START_STOP_CONTINUE
  /// 3 columnas: Mad / Sad / Glad.
  MAD_SAD_GLAD
}

model BoardColumn {
  id       String @id @default(uuid())
  name     String
  order    Int
  wipLimit Int? // Límite de Work in Progress (AC Kanban)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tarea Universal: Soporta Story (Agile), Hito/Tarea (Gantt) y Ticket (ITIL)
model Task {
  id          String     @id @default(uuid())
  mnemonic    String? // Ejemplo: "PROJ-1"
  title       String
  description String?
  type        TaskType   @default(AGILE_STORY)
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)

  // Jerarquía (Subtareas)
  parentId String?
  parent   Task?   @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks Task[]  @relation("SubTasks")

  // Relaciones de Agrupación
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  phaseId String?
  phase   Phase?  @relation(fields: [phaseId], references: [id])

  sprintId String?
  sprint   Sprint? @relation(fields: [sprintId], references: [id])

  // Wave P9 · Agile Maturity (HU-9.2): asignación de Task a Epic.
  // Opcional — la subtask hereda del padre por defecto al crearse pero
  // puede sobreescribirse. ON DELETE SET NULL: borrar Epic NO borra Tasks.
  epicId String?
  epic   Epic?   @relation(fields: [epicId], references: [id], onDelete: SetNull)

  columnId String?
  column   BoardColumn? @relation(fields: [columnId], references: [id])

  assigneeId String?
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])

  // Módulo PMI (Gantt)
  startDate   DateTime?
  endDate     DateTime?
  progress    Int       @default(0) // 0 - 100%
  isMilestone Boolean   @default(false)

  // Dependencias (Gantt)
  predecessors TaskDependency[] @relation("SuccessorTask")
  successors   TaskDependency[] @relation("PredecessorTask")

  /// Wave P14c — Riesgos asociados a esta tarea (Brain AI register).
  risks Risk[] @relation("TaskRisks")

  /// Wave P18-A · Quality Inspections + Defect Tracking.
  inspections QualityInspection[] @relation("TaskInspections")
  defects     Defect[]             @relation("TaskDefects")

  // Módulo ITIL (SLA Management)
  slaResponseLimit   DateTime? // Límite de tiempo para responder
  slaResolutionLimit DateTime? // Límite de tiempo para resolver
  isEscalated        Boolean   @default(false)

  // EVM y KPIs (Horas / Costos)
  plannedValue Float? // PV: Valor Planificado (Costo o esfuerzo base)
  actualCost   Float? // AC: Costo/Esfuerzo real incurrido
  earnedValue  Float? // EV: Valor Ganado (PV * progress/100)

  // Ordenamiento visual en List/Kanban (ADR-001 fractional indexing)
  position Float @default(0)

  // Soft archive para acción "Archivar" del menú contextual
  archivedAt DateTime?

  // Etiquetas libres para filtros/búsqueda
  tags String[] @default([])

  // ── Agile · Story Points (Ola P2) ──────────────────────────────
  // Estimación en escala Fibonacci (1, 2, 3, 5, 8, 13, 21). Nullable
  // porque las tareas PMI/ITIL no se estiman en puntos. La validación
  // del valor permitido vive en el server action (`assignTaskToSprint`
  // y `setTaskStoryPoints`); aquí dejamos el tipo amplio para no atar
  // futuros equipos que quieran extender la escala.
  storyPoints Int?

  /// Wave P9 · Agile Maturity (HU-9.3) — Historia de Usuario formal.
  ///
  /// Aplica sólo a tasks con `type = AGILE_STORY`. JSON con shape:
  ///   {
  ///     asA: string,        // "Como un Project Owner..."
  ///     iWant: string,      // "Quiero crear Epics..."
  ///     soThat: string,     // "Para agrupar Stories..."
  ///     criteria: Array<{
  ///       id: string,       // uuid
  ///       text: string,
  ///       done: boolean,
  ///       doneAt?: string   // ISO date
  ///     }>
  ///   }
  ///
  /// Decisión arquitectura: campo Json en lugar de tabla normalizada
  /// `AcceptanceCriteria`. Razón: criterios viajan con templates, son
  /// raros los queries cross-task ("dame todas las tasks con CA X").
  /// Si crece la necesidad de query, normalizar en R2 (deuda registrada).
  ///
  /// El validador de shape vive en `src/lib/user-story/types.ts`.
  userStory Json?

  /// Fase 1 (2026-05-13) — ITIL Task Attributes. Aplica sólo a tasks con
  /// `type = ITIL_TICKET`. Json con shape:
  ///   {
  ///     recordType: 'Incident'|'Problem'|'Change'|'ServiceRequest'|'Event',
  ///     impact:     'Bajo'|'Medio'|'Alto',
  ///     urgency:    'Baja'|'Media'|'Alta',
  ///     serviceCategory?: string,
  ///     symptom?: string, diagnosis?: string, workaround?: string,
  ///     resolution?: string, rootCause?: string,
  ///     changeType?: 'Standard'|'Normal'|'Emergency',  // solo si recordType=Change
  ///     riskAssessment?, implementationPlan?, rollbackPlan?, cabApproval?,
  ///     changeWindowStart?, changeWindowEnd?
  ///   }
  ///
  /// Decisión arquitectura: Json en lugar de tablas tipadas (deuda Fase 2).
  /// Mismo patrón que `userStory` para acelerar la entrega del flujo de
  /// captura sin requerir migración pesada. Validador en
  /// `src/lib/itil/types.ts`.
  itilAttributes Json?

  // Enlace externo de referencia (Confluence, Figma, ticket externo, etc.)
  referenceUrl String?

  // Ola P5 · Hard deadlines + Resource Leveling.
  // `hardDeadline`: fecha límite forzosa; si la EF de la tarea (calculada
  // por CPM) la supera ⇒ violación que se reporta en /leveling. Distinto
  // de `endDate`: endDate es la fecha planificada (puede moverse), mientras
  // que hardDeadline es un compromiso que NO debe romperse.
  // `dailyEffortHours`: estimación de horas/día por defecto que consume
  // esta tarea para el cálculo de carga del recurso (assignee). Si NULL,
  // el algoritmo de leveling asume `WorkCalendar.workdayHours` o 8h.
  hardDeadline     DateTime?
  dailyEffortHours Float?

  // Seguimiento y comentarios
  comments      Comment[]
  history       TaskHistory[]
  attachments   Attachment[]
  collaborators TaskCollaborator[]

  // Enlace opcional desde nodos de Mapa Mental
  mindMapNodes MindMapNode[] @relation("TaskMindMapNodes")

  // Time Tracking (Ola P1, Equipo 4). La suma de `timeEntries.cost`
  // alimenta `actualCost` real para EVM (HU-2.1+).
  timeEntries TimeEntry[]

  // Custom Fields configurables (Ola P1). Una tarea acumula valores para
  // las definiciones del proyecto; cascade desde la definición y desde la
  // tarea garantiza limpieza al borrar el padre o la propia tarea.
  customFieldValues CustomFieldValue[]

  // Ola P2 · Equipo P2-3 — Recurrencia.
  //
  // Si la tarea fue generada por una RecurrenceRule (cron `scheduleAll`)
  // queda enlazada aquí; al borrar la regla la FK se setea a NULL para
  // preservar el histórico de tareas materializadas.
  recurrenceRuleId String?
  recurrenceRule   RecurrenceRule? @relation("RecurringTaskInstances", fields: [recurrenceRuleId], references: [id], onDelete: SetNull)
  // Fecha "lógica" de la ocurrencia (UTC midnight) usada como llave única
  // junto con `recurrenceRuleId` para garantizar idempotencia del scheduler:
  // si una invocación catch-up corre dos veces no se duplican tasks.
  occurrenceDate   DateTime?

  // Ola P2 · Equipo P2-4 · Goals & OKRs.
  // KRs (con metric=TASKS_COMPLETED) que esta tarea contribuye a alcanzar.
  // M:N a través de la tabla implícita "_KeyResultTasks".
  keyResults KeyResult[] @relation("KeyResultTasks")

  // Ola P5 · Equipo P5-4 · AI Insights heurísticos.
  // Histórico de sugerencias generadas para esta tarea (categorización,
  // riesgo de retraso, etc.). Cascade al borrar la tarea para no dejar
  // huérfanos. La acción `dismissInsight` es soft-delete (setea
  // `dismissedAt`) y NO borra la fila — preservamos el rastro para
  // afinar las heurísticas a futuro.
  insights TaskInsight[]

  // Ola P2 · Equipo P2-5 · Docs / Wikis.
  // Documentos vinculados a esta tarea. `SetNull` en Doc.taskId preserva
  // el doc al eliminar la tarea — mismo criterio que Project.docs.
  docs Doc[]

  // Ola P4 · Equipo P4-5 · Integraciones · GitHub.
  // Vínculos de la tarea a issues/PRs externos en GitHub. Una tarea puede
  // tener múltiples links (ej. issue de bug + PR que lo resuelve).
  githubLinks TaskGitHubLink[]

  // Wave C-debt-1 · Equipo C-DEBT-1 — Checklists relacionales (deuda P7-5).
  // Originalmente P7-5 anexaba el checklist sugerido por IA como markdown a
  // `description`. Ahora cada Task puede tener N checklists (ej. "Definition
  // of Done", "Validación QA") cada una con sus items. Cascade al borrar la
  // tarea para no dejar checklists huérfanos.
  checklists Checklist[]

  // Ola P8 · Equipo P8-3 · Cost Management.
  // Gastos asociados puntualmente a esta task (e.g. licencia, materiales).
  // `SetNull` preserva el gasto si la task se elimina — el gasto sigue
  // perteneciendo al proyecto y reporting EVM.
  expenses Expense[]

  // Wave P10 (HU-10.4) — Dependencias cross-project. La tabla
  // `Dependency` clásica solo cubre intra-project; estas relaciones viven
  // en `CrossProjectDependency` para no romper CPM/Gantt actual.
  crossDepsAsSource CrossProjectDependency[] @relation("CrossDepSource")
  crossDepsAsTarget CrossProjectDependency[] @relation("CrossDepTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recurrenceRuleId, occurrenceDate])
  @@index([projectId, columnId, position])
  @@index([projectId, parentId, position])
  @@index([archivedAt])
}

// Colaboradores adicionales de una tarea (M:N Task ↔ User).
// El `assigneeId` único de Task sigue siendo el responsable principal;
// los colaboradores aquí son destinatarios extra para notificaciones de
// mención y visibilidad del trabajo compartido.
model TaskCollaborator {
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("TaskCollaborator", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// Comentarios / Seguimiento de tareas
model Comment {
  id         String  @id @default(uuid())
  content    String
  isInternal Boolean @default(false) // Seguimiento interno vs externo

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation("CommentAuthor", fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

// Historial de cambios / Auditoría
model TaskHistory {
  id     String @id @default(uuid())
  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  field    String // Campo modificado: "status", "priority", "assigneeId", etc.
  oldValue String?
  newValue String?

  createdAt DateTime @default(now())
}

// Adjuntos / Archivos de respaldo.
//
// Wave P8 · Equipo P8-4 — Supabase Storage real. Se mantienen los campos
// `url`, `size`, `mimetype`, `userId` (legacy, originalmente `Attachment.url`
// guardaba un placeholder/URL externa). Se añaden:
//   - `storagePath`: ruta en bucket `attachments` (`{userId}/{uuid}-{name}`).
//   - `mimeType`, `sizeBytes`: nuevas columnas tipadas (los legacy `mimetype`/
//     `size` quedan en read-only para no romper rows previas).
//   - `uploadedById`/`uploadedBy` (alias semántico de `userId`/`user`). Se
//     mantienen ambos pares de campos en paralelo durante la transición; el
//     código nuevo escribe `uploadedById` + `userId` para compatibilidad.
//
// Acceso al archivo: NUNCA `url` directo. Llamar `getSignedUrl(attachmentId)`
// (server action) que valida `requireProjectAccess` y devuelve URL temporal.
model Attachment {
  id       String  @id @default(uuid())
  filename String
  url      String? // legacy, deprecated; nuevo flujo usa storagePath + signed URL
  size     Int?
  mimetype String? // legacy

  // Wave P8-4 — Nuevos campos para Supabase Storage.
  storagePath  String? // path dentro del bucket `attachments`
  mimeType     String? // mime type validado por whitelist (image/*, application/pdf, ...)
  sizeBytes    Int? // tamaño real del blob subido (cap 25MB)
  uploadedById String? // alias semántico; se persiste junto con `userId`

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  uploadedBy User? @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: SetNull)

  createdAt  DateTime @default(now())
  uploadedAt DateTime @default(now())

  @@index([taskId])
  @@index([uploadedById, uploadedAt])
}

// Dependencias entre tareas (FS, SS, FF, SF)
model TaskDependency {
  id String @id @default(uuid())

  predecessorId String
  predecessor   Task   @relation("PredecessorTask", fields: [predecessorId], references: [id], onDelete: Cascade)

  successorId String
  successor   Task   @relation("SuccessorTask", fields: [successorId], references: [id], onDelete: Cascade)

  type DependencyType @default(FINISH_TO_START)

  // Lag/Lead en días aplicado a la dependencia. Positivo = espera obligatoria
  // (ej. FS+2 = sucesor inicia 2 días después de que el predecesor termine);
  // negativo = lead/solapamiento (ej. FS-1 = sucesor inicia 1 día antes).
  // Usado por el cálculo CPM (forward/backward pass).
  lagDays Int @default(0)

  @@unique([predecessorId, successorId])
}

// Módulo PMI: Líneas Base (Snapshots para calcular Schedule Variance)
model Baseline {
  id           String  @id @default(uuid())
  version      Int // Versión 1, 2, 3... (por proyecto, monótonamente creciente)
  snapshotData Json // Json estructurado con el estado de las tareas (fechas, PV, EV, AC)
  // Etiqueta libre opcional capturada por el usuario para distinguir
  // versiones (≤80 chars). Persistida como columna primera-clase para
  // permitir mostrarla sin parsear el JSON.
  label        String?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // HU-3.1 · Garantía de unicidad por proyecto+versión. Sirve también
  // como guard contra race conditions cuando dos clientes capturan
  // simultáneamente: la 2ª transacción falla con P2002 y la action
  // reintenta con max(version)+1.
  @@unique([projectId, version])
  @@index([projectId, createdAt])
}

// ─────────────────────────────────────────────────────────────
// Módulo Calendarios Laborales (Ola P1.5)
// ─────────────────────────────────────────────────────────────

model WorkCalendar {
  id           String  @id @default(uuid())
  name         String
  isDefault    Boolean @default(false)
  // Bitmask de días laborables (bit 0 = lun, bit 6 = dom).
  // Default: lun-vie = 0b0011111 = 31 (sin sábado ni domingo).
  workdays     Int     @default(31)
  // Horas estándar de jornada laboral (8.00 por defecto).
  workdayHours Decimal @default(8.00) @db.Decimal(4, 2)

  holidays Holiday[]
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id         String       @id @default(uuid())
  calendarId String
  calendar   WorkCalendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  // Fecha del festivo (almacenada como UTC midnight).
  date       DateTime
  name       String
  // Si true ⇒ se repite cada año (se compara solo mes/día).
  recurring  Boolean      @default(false)

  createdAt DateTime @default(now())

  @@unique([calendarId, date])
  @@index([calendarId, date])
}

// ─────────────────────────────────────────────────────────────
// Módulo Mapas Mentales (estilo MindMup 3)
// ─────────────────────────────────────────────────────────────

model MindMap {
  id          String  @id @default(uuid())
  title       String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("MindMapOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  nodes MindMapNode[]
  edges MindMapEdge[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([ownerId])
}

model MindMapNode {
  id String @id @default(uuid())

  mindMapId String
  mindMap   MindMap @relation(fields: [mindMapId], references: [id], onDelete: Cascade)

  label  String  @default("Nuevo nodo")
  note   String? // Markdown o texto libre (nota expandida)
  x      Float   @default(0)
  y      Float   @default(0)
  color  String?
  isRoot Boolean @default(false)

  // Enlace opcional a Task
  taskId String?
  task   Task?   @relation("TaskMindMapNodes", fields: [taskId], references: [id], onDelete: SetNull)

  sourceEdges MindMapEdge[] @relation("EdgeSource")
  targetEdges MindMapEdge[] @relation("EdgeTarget")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mindMapId])
  @@index([taskId])
}

model MindMapEdge {
  id String @id @default(uuid())

  mindMapId String
  mindMap   MindMap @relation(fields: [mindMapId], references: [id], onDelete: Cascade)

  sourceId String
  source   MindMapNode @relation("EdgeSource", fields: [sourceId], references: [id], onDelete: Cascade)

  targetId String
  target   MindMapNode @relation("EdgeTarget", fields: [targetId], references: [id], onDelete: Cascade)

  label String?

  createdAt DateTime @default(now())

  @@unique([sourceId, targetId])
  @@index([mindMapId])
}

// ─────────────────────────────────────────────────────────────
// Módulo Time Tracking (Ola P1 · Equipo 4)
//
// Permite que cada miembro registre tiempo trabajado en tareas, ya sea
// con un timer en vivo (`endedAt = null`) o como entrada manual con
// rango cerrado. La suma de `cost` por tarea alimenta `Task.actualCost`
// real para EVM (HU-2.1+), reemplazando el valor estimado.
//
// Decisiones:
//   1. `hourlyRate` se persiste como SNAPSHOT al cerrar el timer (o al
//      crear el entry manual). Esto evita que cambios futuros de tarifa
//      reescriban la historia financiera.
//   2. `durationMinutes` es 0 mientras el timer corre y se calcula al
//      hacer stop. Mantenerlo materializado hace baratos los reportes de
//      timesheet semanal sin necesidad de calcular `endedAt - startedAt`
//      en cada query.
//   3. `cost` es nullable: un entry sin tarifa vigente no rompe el flujo
//      (sólo no contribuye a EVM). Operaciones administrativas pueden
//      backfillear costos cuando se asigne tarifa retroactiva.
// ─────────────────────────────────────────────────────────────

model TimeEntry {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId          String
  task            Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  endedAt         DateTime? // null mientras el timer corre
  durationMinutes Int       @default(0) // 0 mientras corre; calculado al cerrar
  description     String?
  hourlyRate      Decimal?  @db.Decimal(10, 2) // snapshot al cerrar
  cost            Decimal?  @db.Decimal(12, 2) // duration * rate
  createdAt       DateTime  @default(now())

  @@index([userId, startedAt(sort: Desc)])
  @@index([taskId, startedAt(sort: Desc)])
}

// Tarifa horaria de un usuario, válida en un rango de fechas.
// `validUntil = null` indica tarifa vigente. Históricamente conservamos
// los rangos cerrados para auditoría y para snapshot retroactivo.
model UserHourlyRate {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rate       Decimal   @db.Decimal(10, 2)
  validFrom  DateTime
  validUntil DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, validFrom])
}

// Módulo Custom Fields (Ola P1 · Equipo 3)
//
// Permite que cada gerencia/proyecto defina campos personalizados sobre
// `Task` (texto, número, fecha, select, multi-select, booleano, URL).
// Cada `CustomFieldDef` pertenece a un único proyecto; los valores
// (`CustomFieldValue`) están unidos a la tupla (definición, tarea) y
// cascadean al borrarse la definición o la tarea.
// ─────────────────────────────────────────────────────────────

model CustomFieldDef {
  id           String          @id @default(uuid())
  projectId    String
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // Slug estable usado en API/exports (ej. "cliente_codigo"); único por
  // proyecto. La label es la versión human-readable mostrada en la UI.
  key          String
  label        String
  type         CustomFieldType
  required     Boolean         @default(false)
  defaultValue Json?
  // Para SELECT/MULTI_SELECT, array de `{ value, label }` validado en el
  // server action. Para otros tipos debe ser `null`.
  options      Json?
  // Orden visual configurable; permite reordenar con drag-handle sin
  // reescribir todos los registros (esquema fractional indexing).
  position     Float           @default(1)
  createdAt    DateTime        @default(now())

  values CustomFieldValue[]

  @@unique([projectId, key])
  @@index([projectId, position])
}

model CustomFieldValue {
  id      String         @id @default(uuid())
  fieldId String
  field   CustomFieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  taskId  String
  task    Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Valor serializado en JSON; el shape concreto depende de `field.type`
  // (string | number | ISO date | boolean | string | string[] | url).
  // La validación se centraliza en `setTaskFieldValue`.
  value   Json

  @@unique([fieldId, taskId])
  @@index([taskId])
}

// Módulo Centro de notificaciones (Ola P1 · HU-N1.x)
// ─────────────────────────────────────────────────────────────

// Notificación in-app dirigida a un usuario. Contraparte canal-app del
// email de mención que ya despacha `sendMentionNotification`.
//
// Reglas:
//   - `link` es relativo (ej. "/gantt?taskId=xxx"); el cliente lo abre con
//     <Link href>.
//   - `data` está reservado para metadatos extra opcionales (counts del
//     import, version de la baseline, etc.). Mantener el shape pequeño:
//     UI no debería depender de campos profundos.
//   - Sin `updatedAt`: el único mutable es `readAt` y se actualiza con
//     `markNotificationRead`/`markAllNotificationsRead`.
//   - Índices: la consulta por defecto es `userId, createdAt desc` y el
//     count de no-leídas filtra por `userId, readAt is null`.
model Notification {
  id     String           @id @default(uuid())
  userId String
  user   User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type   NotificationType
  title  String
  body   String?
  link   String? // URL relativa para navegar (ej. "/gantt?taskId=xxx")
  data   Json? // metadata extra (count, version, taskId…)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt(sort: Desc)])
}

// Preferencias por usuario para canales de notificación. En P1 los toggles
// in-app están siempre activos (no se exponen aquí); solo controlamos el
// canal email. `emailDigest` queda reservado para Ola P2 (digest diario).
model NotificationPreference {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  emailMentions    Boolean @default(true)
  emailAssignments Boolean @default(true)
  emailDigest      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
// Módulo Web Push (Wave P6 · Equipo A4 · extendido Wave R4-B)
//
// Persistencia de suscripciones del navegador (PushManager.subscribe) y
// de dispositivos nativos Capacitor (APNs/FCM). Cada `endpoint` es único:
//   - WEB_PUSH → URL del push service (FCM/Mozilla/Apple) + `keys`
//     `{ p256dh, auth }` para cifrado E2E (RFC 8291).
//   - APNS     → device token APNs (Apple Push Notification service).
//     `keys` NULL — el cifrado lo gestiona TLS contra Apple.
//   - FCM      → registration token Firebase Cloud Messaging. `keys` NULL.
// `userAgent` es informativo (UI de "dispositivos activos") y `lastUsedAt`
// se actualiza al enviar push correctamente para limpieza de inactivas.
// FK a User con CASCADE: al borrar usuario se eliminan suscripciones.
// ─────────────────────────────────────────────────────────────

/// Wave R4-B · Tipo de transporte de la suscripción push.
enum PushSubscriptionKind {
  WEB_PUSH // browser estándar (VAPID + p256dh+auth)
  APNS     // iOS Capacitor (device token APNs)
  FCM      // Android Capacitor (registration token FCM)
}

model PushSubscription {
  id         String               @id @default(uuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String               @unique
  /// Para WEB_PUSH: { p256dh, auth }. Para APNS/FCM: NULL.
  keys       Json?
  /// Wave R4-B · transporte del device. Default WEB_PUSH (backfill rows P6).
  kind       PushSubscriptionKind @default(WEB_PUSH)
  userAgent  String?
  createdAt  DateTime             @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@index([kind])
}

// ─────────────────────────────────────────────────────────────
// Módulo Vistas Guardadas (Ola P2 · Equipo P2-1)
//
// Persistencia de configuraciones de filtros + grouping + columnas para
// equiparar paridad con ClickUp. Cada vista pertenece a un usuario y a una
// superficie (LIST/KANBAN/GANTT/CALENDAR/TABLE). `isShared=true` permite
// que la vista sea visible para todos los users del proyecto/org (la
// permission real se verifica en el server action vía requireUser).
// ─────────────────────────────────────────────────────────────

model SavedView {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  surface     ViewSurface
  // Estructura serializada de TaskFilters (zod-validada en server action).
  filters     Json
  // null | 'assignee' | 'sprint' | 'phase' | 'status' | 'tags' | 'priority' |
  // 'custom_field:<id>'. Validado contra GROUPING_KEYS en runtime.
  grouping    String?
  // { field, direction: 'asc' | 'desc' } opcional.
  sorting     Json?
  // visibility/order de columnas (para Table). Shape libre validado en cliente.
  columnPrefs Json?
  // true ⇒ visible para todos los users (lectura compartida; la edición
  // sigue restringida al owner).
  isShared    Boolean     @default(false)
  // 1 default por usuario por surface. Mantenemos la unicidad en código
  // (setDefaultView lo desmarca antes de marcar) para evitar migraciones
  // condicionales con WHERE en Postgres.
  isDefault   Boolean     @default(false)
  // Fractional indexing para reordenar sin reescribir todos los registros.
  position    Float       @default(1)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, surface])
  @@index([surface, isShared])
}

// Módulo Templates + Recurrencia (Ola P2 · Equipo P2-3)
//
// Permite (1) guardar plantillas reutilizables de tasks y (2) configurar
// reglas de recurrencia inspiradas en iCalendar RRULE para generar tasks
// periódicamente vía cron / Server Action `scheduleAll`.
//
// Decisiones documentadas:
//   D-RT-1: `taskShape` se persiste como JSON snapshot (no FK al Task que
//           sirvió de origen) para que renombrar/borrar la task fuente
//           no rompa el template.
//   D-RT-2: Un template puede ser global (`projectId = null`) o per-project;
//           los globales sirven a toda la organización (ej. plantillas
//           ITIL estándar).
//   D-RT-3: `byweekday` y `bymonthday` se modelan como `Int[]` —
//           Postgres soporta arrays nativos y Prisma los expone como
//           `number[]`. Bitmask Lun=0..Dom=6 (ISO weekday - 1).
//   D-RT-4: `lastGeneratedAt` se actualiza por el scheduler tras cada
//           materialización exitosa; combinado con la `@@unique` en Task
//           (`recurrenceRuleId, occurrenceDate`) garantiza idempotencia.
// ─────────────────────────────────────────────────────────────

model TaskTemplate {
  id          String  @id @default(uuid())
  name        String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Snapshot inmutable del task: { title, description, type, priority,
  // durationDays, tags[], referenceUrl, isMilestone, ... }. Validado por
  // zod en el server action al crear/actualizar.
  taskShape Json

  createdById String
  createdBy   User   @relation("TaskTemplateAuthor", fields: [createdById], references: [id], onDelete: Cascade)

  // Cuando true, el template aparece en la lista de todos los proyectos
  // del usuario. Independiente de `projectId`: un template global
  // (`projectId = null`) puede aún no estar compartido si lo usa un solo
  // gerente.
  isShared Boolean @default(false)

  recurrences RecurrenceRule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([createdById])
}

model RecurrenceRule {
  id         String       @id @default(uuid())
  templateId String
  template   TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  frequency RecurrenceFreq
  // Cada N freqs (ej. interval=2 + WEEKLY = "cada 2 semanas").
  interval  Int            @default(1)

  // ISO weekday - 1 (Lun=0..Dom=6). Vacío = todos los días de la semana.
  byweekday  Int[] @default([])
  // Día del mes 1..31. Vacío = el día derivado de `startDate`.
  bymonthday Int[] @default([])

  startDate DateTime
  endDate   DateTime?
  // Máximo de ocurrencias absolutas (count + endDate son excluyentes en
  // semántica RRULE; aquí permitimos ambos pero `count` siempre gana).
  count     Int?

  generatedTasks  Task[]    @relation("RecurringTaskInstances")
  lastGeneratedAt DateTime?
  active          Boolean   @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, lastGeneratedAt])
  @@index([templateId])
}

// Módulo Goals / OKRs (Ola P2 · Equipo P2-4)
//
// Representa Objectives + Key Results al estilo OKR clásico:
//   - Goal = Objective: meta cualitativa de un ciclo (Q/H/Y), opcionalmente
//     anclada a un proyecto. Soporta jerarquía (sub-goals) vía `parentId`.
//   - KeyResult: métrica medible que contribuye a un Goal. Cuatro tipos
//     (PERCENT/NUMERIC/BOOLEAN/TASKS_COMPLETED). Para TASKS_COMPLETED el
//     `currentValue` es porcentaje (0-100) recalculado al completar tasks
//     vinculadas (`linkedTasks`).
// ─────────────────────────────────────────────────────────────

model Goal {
  id          String  @id @default(uuid())
  title       String
  description String?

  // Owner principal del Objective. Restringimos a la User table (no SetNull):
  // un OKR sin owner pierde sentido; si se elimina el usuario el caller debe
  // reasignar antes (validado vía server action / trigger UI).
  ownerId String
  owner   User   @relation("GoalOwner", fields: [ownerId], references: [id])

  // Proyecto opcional al que se ancla el Objective (Goals corporativos
  // pueden no tener proyecto). `SetNull` preserva histórico al borrar el
  // proyecto.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  status GoalStatus @default(ON_TRACK)

  // Etiqueta libre del ciclo OKR: "Q1-2026", "H1-2026", "Y2026". Se valida
  // con regex en el server action (`isValidCycle`).
  cycle String

  // Ventana temporal del Objective. Permite calcular daysElapsed/totalDays
  // para `classifyGoalStatus`.
  startDate DateTime
  endDate   DateTime

  // Jerarquía Goal → sub-Goals (Company → Team → Personal). `SetNull` al
  // borrar el padre evita perder los hijos: quedan huérfanos pero
  // accesibles. La UI permite re-anclar.
  parentId String?
  parent   Goal?   @relation("GoalHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Goal[]  @relation("GoalHierarchy")

  // Resultados clave del Objective. Cascade: borrar el Goal borra todos
  // sus KRs (no tiene sentido un KR huérfano).
  keyResults KeyResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Patrones de query del dashboard:
  //   - "todos los goals de Edwin en Q1-2026" → (ownerId, cycle).
  //   - "todos los goals del proyecto X en H1-2026" → (projectId, cycle).
  @@index([ownerId, cycle])
  @@index([projectId, cycle])
  @@index([parentId])
}

model KeyResult {
  id String @id @default(uuid())

  goalId String
  goal   Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  title        String
  metric       KeyResultMetric
  // Valor objetivo. Para PERCENT y TASKS_COMPLETED suele ser 100; para
  // NUMERIC depende de unit; para BOOLEAN es 1.
  targetValue  Float
  // Valor actual. Para TASKS_COMPLETED se recalcula automáticamente al
  // completar tareas vinculadas.
  currentValue Float           @default(0)
  // Unidad opcional human-readable (USD, %, users…). Solo se muestra en
  // la UI; no afecta cálculo.
  unit         String?
  // Orden visual del KR dentro del Goal (fractional indexing).
  position     Float           @default(1)

  // Tasks vinculadas — solo relevante cuando `metric=TASKS_COMPLETED`. M:N
  // implícita ("_KeyResultTasks"). El recompute consulta status=DONE.
  linkedTasks Task[] @relation("KeyResultTasks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId, position])
}

// ─────────────────────────────────────────────────────────────
// Módulo Public Forms + Automation Engine (Ola P5 · Equipo P5-5)
//
// 1. PublicForm + FormSubmission: captura externa (sin auth) de tickets/
//    requerimientos. Cada PublicForm define su shape en `schema` (Json) y
//    un `targetTaskTitleTemplate` con interpolación `{campo}` para crear
//    Tasks automáticamente al recibir submissions.
// 2. AutomationRule + AutomationExecution: motor "if-this-then-that"
//    interno. Ejecutado desde server actions mediante `runAutomations`.
//    `trigger` describe el evento, `conditions` filtra el contexto y
//    `actions` lista pasos secuenciales (createTask, sendWebhook,
//    updateField, assignUser).
//
// Decisiones documentadas (D-FA-*):
//   D-FA-1: `slug` del PublicForm es ÚNICO (no únicamente por proyecto)
//           porque la URL `/forms/[slug]` es global y pública.
//   D-FA-2: `FormSubmission.taskId` es SetNull para preservar la submission
//           histórica aunque la task generada se borre.
//   D-FA-3: `AutomationRule` no tiene unique compuesto; la app permite
//           múltiples reglas con el mismo trigger (cadenas if-this-then-
//           that paralelas). El anti-loop se hace en runtime.
//   D-FA-4: `AutomationExecution.result` guarda { actions: [...] } con el
//           detalle de cada paso (ok, error, output) para auditoría.
// ─────────────────────────────────────────────────────────────

model PublicForm {
  id          String  @id @default(uuid())
  // URL pública: /forms/<slug>. Único globalmente (D-FA-1).
  slug        String  @unique
  title       String
  description String?

  // Proyecto opcional al que se anclan las tasks creadas. SetNull para
  // preservar formularios huérfanos ante borrado del proyecto.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Lista de campos: [{ name, type, label?, required, options? }, ...]
  // Validado por zod en el server action; aquí Json libre.
  schema Json

  // Plantilla del título de Task generada al recibir submission.
  // Interpolación `{nombre}`, `{email}`, etc.
  targetTaskTitleTemplate String @default("Submission de {slug}")

  isActive Boolean @default(true)

  submissions FormSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([projectId])
}

model FormSubmission {
  id     String     @id @default(uuid())
  formId String
  form   PublicForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  // Payload bruto del submit (clave=valor por nombre del campo).
  payload Json

  // Task generada por la regla (opcional). SetNull (D-FA-2).
  taskId String?

  // Metadatos anti-spam / auditoría.
  ip        String?
  userAgent String?

  submittedAt DateTime @default(now())

  @@index([formId, submittedAt(sort: Desc)])
  @@index([ip, submittedAt(sort: Desc)])
}

model AutomationRule {
  id   String @id @default(uuid())
  name String

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // { event: 'task.created' | 'status.changed' | 'form.submitted', ... }
  trigger Json

  // Lista de filtros [{ field, op, value }] con op = '=' | '!=' | '>' | '<' | 'contains'.
  conditions Json @default("[]")

  // Lista de acciones [{ kind: 'createTask' | 'sendWebhook' | 'updateField' | 'assignUser', ... }]
  actions Json @default("[]")

  isActive Boolean @default(true)

  executions AutomationExecution[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([projectId])
}

model AutomationExecution {
  id     String         @id @default(uuid())
  ruleId String
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  // Identificador del agente disparador: "task:<id>", "form:<slug>", "user:<id>"…
  triggeredBy String

  // 'success' | 'failed' (string libre para evitar acoplar enum a runtime).
  status String

  // { actions: [{ kind, ok, output?, error? }], skippedReason? }
  result Json

  executedAt DateTime @default(now())

  @@index([ruleId, executedAt(sort: Desc)])
  @@index([status, executedAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────
// Módulo Whiteboards (Ola P5 · Equipo P5-1)
//
// Pizarras colaborativas estilo Miro: canvas con sticky notes, formas,
// conectores y texto. Cada elemento se posiciona libremente en un plano
// 2D infinito (zoom + pan); el editor cliente persiste posiciones con
// autosave debounced.
//
// Decisiones autónomas (P5-1):
//   D-WB-1: `data` se almacena como JSON único por elemento — el shape
//           depende del `type` (sticky: {color,text}; shape:
//           {variant:'rectangle'|'circle',fill,stroke}; connector:
//           {fromId,toId,points[]}). Esto evita N tablas para 5 tipos
//           y permite añadir variantes sin migración.
//   D-WB-2: `zIndex` materializado (no orderBy createdAt) para soportar
//           "traer al frente / enviar al fondo" estable y deterministico.
//   D-WB-3: `projectId` opcional — pizarras pueden ser personales (sin
//           proyecto). Cuando hay projectId, server actions exigen
//           `requireProjectAccess`.
//   D-WB-4: `isArchived` en lugar de delete físico para soporte de
//           "papelera" futura. Las queries por defecto filtran archivadas.
//   D-WB-5: No modelamos `workspaceId` — el schema actual no expone Workspace.
//           Cuando llegue, se añade como FK SetNull en una migración futura.
// ─────────────────────────────────────────────────────────────

model Whiteboard {
  id          String  @id @default(uuid())
  title       String
  description String?

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("WhiteboardCreator", fields: [createdById], references: [id], onDelete: SetNull)

  isArchived Boolean @default(false)

  // R4-D · Whiteboards co-edit · Snapshot Yjs del conjunto de elementos
  // como `Y.Map<elementId, Y.Map<field, value>>`. Coexistente con la tabla
  // `WhiteboardElement` (legacy): el editor reconcilia el state Yjs con la
  // BD relacional al `saveWhiteboardYjsState` (server action).
  // Nullable; lazy-init desde la lista de elementos al primer co-edit.
  stateYjs Bytes?

  elements WhiteboardElement[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, isArchived])
  @@index([createdById])
}

model WhiteboardElement {
  id           String                @id @default(uuid())
  whiteboardId String
  whiteboard   Whiteboard            @relation(fields: [whiteboardId], references: [id], onDelete: Cascade)
  type         WhiteboardElementType

  // Coordenadas y dimensiones en el plano infinito (Float para soportar
  // zoom + snap a sub-pixel).
  x        Float @default(0)
  y        Float @default(0)
  width    Float @default(160)
  height   Float @default(120)
  rotation Float @default(0)

  // Payload tipado por `type` (ver D-WB-1). Validado en el server action
  // (`validateElementData`).
  data Json

  // Stack order — mayor z-index dibuja encima. El editor reasigna en lote
  // al "traer al frente / enviar al fondo".
  zIndex Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([whiteboardId, zIndex])
}

// ─────────────────────────────────────────────────────────────
// Módulo AI Insights heurísticos (Ola P5 · Equipo P5-4)
//
// Persistencia de sugerencias generadas por heurísticas locales (sin
// LLM externo en este sprint). Cada fila documenta:
//   - `kind`: tipo de insight (categorización / riesgo / next-action).
//   - `score`: confianza (categorización/next-action) o nivel de riesgo
//      (delay) en el rango 0..1.
//   - `payload`: detalle estructurado (suggestedType, factors[], etc.).
//
// Decisiones:
//   D-AI-1: `taskId` es required + cascade. Para insights "global" del
//           proyecto (NEXT_ACTION) usamos un task representativo (la
//           primera task pendiente del proyecto) o creamos un sentinel.
//           En la práctica el server action siempre tiene un taskId
//           válido.
//   D-AI-2: `dismissedAt` es soft-delete: la UI filtra sólo los activos
//           pero conservamos el histórico para afinar las heurísticas.
//   D-AI-3: índice `(taskId, kind, createdAt)` para la query típica
//           "últimos insights por tarea agrupados por kind".
// ─────────────────────────────────────────────────────────────

model TaskInsight {
  id          String      @id @default(uuid())
  taskId      String
  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  kind        InsightKind
  // Score 0..1. Para CATEGORIZATION = confianza; DELAY_RISK = severidad;
  // NEXT_ACTION = relevancia (mayor = más urgente).
  score       Float
  // Estructura libre validada por zod en el server action según `kind`.
  payload     Json
  // Soft-delete: la UI filtra `dismissedAt IS NULL`.
  dismissedAt DateTime?
  createdAt   DateTime    @default(now())

  @@index([taskId, kind, createdAt(sort: Desc)])
  @@index([kind, dismissedAt])
}

// ─────────────────────────────────────────────────────────────
// Ola P4 · Equipo P4-1 — Multi-tenancy / Workspaces.
//
// Modelo:
//   - Workspace             : organización lógica que agrupa Projects,
//                             Goals, Templates, etc. Soporta plan comercial
//                             (FREE/PRO/ENTERPRISE) y posee un OWNER.
//   - WorkspaceMember       : tabla pivote M:N User ↔ Workspace con `role`
//                             (OWNER/ADMIN/MEMBER). PK compuesta para
//                             garantizar membresía única.
//   - WorkspaceInvitation   : invitación por email con token aleatorio y
//                             expiración. Una vez aceptada se elimina y se
//                             crea el WorkspaceMember correspondiente.
//
// Estrategia de migración (P4 inicial):
//   - `Project.workspaceId` opcional ahora; helper
//     `getDefaultWorkspaceForUser(userId)` crea/devuelve un WS por defecto
//     para usuarios legacy.
//   - Las server actions filtran por `workspaceId` activo de la sesión vía
//     cookie `x-active-workspace`.
// ─────────────────────────────────────────────────────────────

model Workspace {
  id   String @id @default(uuid())
  name String

  // Slug URL-safe único globalmente. La validación (lowercase, sin espacios)
  // vive en el server action `createWorkspace`. Se persiste en lower-case.
  slug String @unique

  /// Wave P17-C — Descripción opcional editable desde el panel /admin.
  description String?

  plan WorkspacePlan @default(FREE)

  // Owner único del workspace. Restrict para evitar borrar al dueño sin
  // transferir antes la propiedad (handler explícito en server action).
  ownerId String
  owner   User   @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  members     WorkspaceMember[]
  invitations WorkspaceInvitation[]
  projects    Project[]

  // Wave P11-PMI (HU-12.4) — Procurement (Vendor catálogo del workspace)
  vendors Vendor[]

  // Wave P17-B · Equipo B — API pública v2 + Webhooks v2 (workspace-scoped).
  apiKeys              ApiKey[]
  webhookSubscriptions WebhookSubscription[]

  /// Wave P17-C — Plantillas globales clonadas/asociadas a este workspace.
  globalTemplates GlobalTemplate[]

  /// R3.0 Fase 2 · SSO/SAML — Proveedores de identidad SAML por workspace
  /// (un workspace puede federar contra Azure AD + Okta simultáneamente).
  ssoProviders SsoProvider[]

  /// R3.0-F — Data Retention Policies por dominio (AUDIT_LOG/SESSION/
  /// NOTIFICATION/BRAIN_INSIGHT). Cascade: archivar workspace borra sus
  /// policies (no es destructivo: las defaults se re-siembran al
  /// reactivar el WS via `ensureDefaultPolicies`).
  retentionPolicies RetentionPolicy[]

  /// Wave P20-C — Auto-Pilot history (cross-project optimization runs).
  autoPilotRuns AutoPilotRun[]

  /// Wave R4-E · Monetización SaaS — relación 1-1 con BillingSubscription.
  /// Cascade: borrar/archivar WS purga la subscripción Stripe asociada
  /// (la cancelación efectiva en Stripe la hace el webhook + el helper
  /// `cancelSubscription`, no la BD).
  billingSubscription BillingSubscription?
  /// Wave R4-E — histórico de facturas Stripe persistidas por el webhook.
  billingInvoices     BillingInvoice[]

  /// Wave R4-E — Contador in-DB de Brain AI calls del periodo en curso.
  /// MVP sin Redis: cada llamada incrementa, el cron mensual resetea.
  /// Si excede `tier.brainCalls`, `requireCapacity('brainCalls', current)`
  /// lanza `[CAPACITY_EXCEEDED]`. Default 0.
  brainCallsThisMonth Int       @default(0)
  /// Wave R4-E — Timestamp del último reset (cron mensual). Útil para
  /// debug y para mostrar a usuarios "se reseteará el X de mes".
  brainCallsResetAt   DateTime?

  /// Wave R4-E · Onboarding flow — flag idempotente. NULL = onboarding
  /// pendiente; set en `markOnboardingCompleted()` cuando el usuario cierra
  /// el modal o lo skipea explícitamente.
  onboardingCompletedAt DateTime?

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  /// Wave P17-C — Soft delete. Workspaces archivados no aparecen en el
  /// switcher activo pero conservan el historial para auditoría.
  archivedAt DateTime?

  @@index([ownerId])
}

// ─────────────────────────────────────────────────────────────
// Wave R4-E · Monetización SaaS externa (Stripe).
//
// Permite spin-off de Sync como producto SaaS comercializable:
//   - `BillingSubscription` (1-1 con Workspace) refleja el estado Stripe.
//   - `BillingInvoice` materializa el histórico para UI sin round-trips
//     a Stripe (que tiene rate limits y latencia).
//
// Decisiones documentadas:
//   D-R4E-1: 1 sub por WS (vs por user). Stripe `quantity` representa
//            asientos (`seats`); el monto = priceMonthly × seats.
//   D-R4E-2: `tier` es String (no enum) para tolerar planes promocionales
//            o experimentales sin migración. La validación canónica vive
//            en `src/lib/billing/pricing.ts::PRICING_TIERS`.
//   D-R4E-3: `BillingInvoice.stripeInvoiceId` es @unique → idempotencia
//            del webhook (replays del mismo invoice.paid no duplican).
//   D-R4E-4: `BillingSubscription.workspaceId` es @unique (1-1). Si en
//            el futuro queremos múltiples subs (ej. add-ons), migrar a
//            `WorkspaceAddon` separado en lugar de relajar este unique.
//   D-R4E-5: Cascade onDelete: archivar WS purga su BillingSubscription
//            local. La cancelación efectiva en Stripe la hace el server
//            action `cancelSubscription` o el webhook customer.deleted.
// ─────────────────────────────────────────────────────────────

model BillingSubscription {
  id String @id @default(uuid())

  /// 1-1 con Workspace. Cascade onDelete (D-R4E-5).
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Stripe customer ID (`cus_xxx`). Null hasta que el WS hace su primer
  /// checkout (workspaces nuevos arrancan FREE sin tocar Stripe).
  stripeCustomerId String?
  /// Stripe subscription ID (`sub_xxx`). Null mientras esté en FREE.
  stripeSubscriptionId String? @unique
  /// Stripe price ID (`price_xxx`) del plan suscrito.
  stripePriceId String?

  /// Plan vigente: FREE / PRO / ENTERPRISE (string libre — ver D-R4E-2).
  tier String @default("FREE")

  /// Estado Stripe canónico: active / past_due / canceled / trialing /
  /// incomplete / incomplete_expired / unpaid. Default `active` para FREE.
  status String @default("active")

  /// Fin del periodo facturado actual. UI muestra "Renueva el X".
  currentPeriodEnd DateTime?
  /// Si el WS marcó cancelación, fecha en que efectivamente se baja.
  /// Mientras `cancelAt > now`, el WS conserva sus features paid.
  cancelAt DateTime?
  /// Si el WS está en trial gratuito, fecha de fin. UI muestra banner.
  trialEndsAt DateTime?

  /// Cantidad de seats incluidos en la sub (Stripe `quantity`). Default 1
  /// para FREE; el `requireCapacity('users', …)` valida contra
  /// `PRICING_TIERS[tier].users` (que puede ser distinto de `seats` si el
  /// tier tiene users máximos por seat, ej. PRO=25 users por 1 seat).
  seats Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stripeCustomerId])
  @@index([status])
}

model BillingInvoice {
  id              String @id @default(uuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Stripe invoice ID (`in_xxx`). @unique → key de idempotencia.
  stripeInvoiceId String @unique
  /// Monto en centavos. Stripe usa enteros para evitar floats.
  amountCents     Int
  /// ISO 4217 lowercase (`usd`, `mxn`, etc.). Default usd.
  currency        String @default("usd")
  /// Stripe status: paid / open / void / uncollectible / draft.
  status          String

  /// URL del PDF de Stripe. La UI ofrece descarga directa.
  invoicePdfUrl   String?

  /// Periodo facturado (Stripe `period_start` / `period_end`).
  periodStart     DateTime
  periodEnd       DateTime

  createdAt       DateTime @default(now())

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([status])
}

model WorkspaceMember {
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([workspaceId, userId])
  @@index([userId])
}

model WorkspaceInvitation {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  email     String
  // Token aleatorio (base64url, 32 bytes) que el invitee abre desde
  // `/invite/[token]`. Único globalmente para evitar colisiones cross-WS.
  token     String        @unique
  role      WorkspaceRole @default(MEMBER)
  expiresAt DateTime

  // Quien envió la invitación (auditoría). SetNull para conservar registro
  // si el inviter es eliminado.
  invitedById String?
  invitedBy   User?   @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([workspaceId])
  @@index([email])
}

// ─────────────────────────────────────────────────────────────
// Módulo API REST pública v1 + Webhooks (Ola P4 · Equipo P4-2)
//
// Permite que clientes externos (CI, scripts, integraciones) interactúen
// con FollowupGantt vía HTTP estándar usando tokens portables. La
// autenticación es Bearer-token sobre header Authorization; los scopes
// (JSON array) gobiernan qué endpoints puede invocar cada token.
//
// Decisiones documentadas:
//   D-API-1: El token se persiste HASHEADO (SHA-256) en `tokenHash`. El
//            valor en claro solo se muestra una vez al crearlo. El prefix
//            (`fg_xxxxxx…`) se guarda en `prefix` para mostrar listados.
//   D-API-2: `scopes Json` = array de strings tipo `projects:read`,
//            `tasks:write`, `webhooks:admin`. Ver `src/lib/api/scopes.ts`.
//   D-API-3: `expiresAt` opcional — null = no expira. La expiración se
//            verifica en cada request (no se usa cron de purga).
//   D-API-4: Webhook.events es array de strings (`task.created`,
//            `baseline.captured`, etc.). El dispatcher filtra hooks
//            activos cuyo `events` contenga el eventType disparado.
//   D-API-5: Firma HMAC SHA-256 sobre el body JSON, header
//            `X-FollowupGantt-Signature: sha256=<hex>`. Receptor verifica
//            con su `secret`.
// ─────────────────────────────────────────────────────────────

model ApiToken {
  id         String    @id @default(uuid())
  // Etiqueta human-readable elegida por el usuario (ej. "CI Vercel", "Script Edwin").
  name       String
  // Hash SHA-256 (hex) del token completo. NUNCA almacenamos el token claro.
  tokenHash  String    @unique
  // Primeros 12 chars del token (incluye prefijo `fg_`) para mostrar en lista
  // sin exponer el resto. Visual hint para que el usuario reconozca cuál revocar.
  prefix     String
  // Array de scopes JSON: ["projects:read","tasks:write",…]. Validado contra
  // `KNOWN_SCOPES` en `src/lib/api/scopes.ts`.
  scopes     Json
  // Owner del token. Cascade: si se elimina el usuario, sus tokens se purgan.
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Opcional: null = no expira. Si está en el pasado el auth helper devuelve 401.
  expiresAt  DateTime?
  // Timestamp del último uso (set on auth-success). Útil para auditoría +
  // detectar tokens dormidos. Best-effort: el update es fire-and-forget.
  lastUsedAt DateTime?
  revokedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([revokedAt])
}

model Webhook {
  id                 String    @id @default(uuid())
  // URL del receptor (https only se valida en server action). Hasta 2048 chars.
  url                String
  // Secret hex (≥32 chars). Lo usa el dispatcher como key del HMAC.
  secret             String
  // Array de eventTypes suscritos: ["task.created","baseline.captured",…].
  events             Json
  // Permite pausar el webhook sin borrarlo (preserva secret + url).
  active             Boolean   @default(true)
  // Owner: cascade al borrar el usuario. (No project-scoped: los webhooks son
  // globales por usuario; futura iteración puede agregar projectId nullable.)
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Estadísticas básicas para troubleshooting; el dispatcher las actualiza
  // best-effort tras cada delivery.
  lastDeliveryAt     DateTime?
  lastDeliveryStatus Int?
  failureCount       Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([active])
}

// ─────────────────────────────────────────────────────────────
// Módulo API Pública v2 + Webhooks v2 (Wave P17-B · Equipo B)
//
// Evolución de los `ApiToken`/`Webhook` v1 con foco enterprise:
//   - Workspace-scoped (vs user-scoped en v1) — permite issuing por
//     integración corporativa (SAP, Power BI, etc.) sin atar la credencial
//     al usuario individual.
//   - `ApiKey.scopes string[]` (no Json) → indexable + queryable.
//   - `WebhookSubscription` separa metadatos (url, secret, events) del
//     histórico de entregas (`WebhookDelivery`). Permite auditoría +
//     reintentos puntuales sin perder contexto.
//   - Retry exponencial 1s/5s/30s en dispatcher con auto-disable tras 10
//     fallos consecutivos (cumple SLO de receptores tolerantes a fallos).
//
// Decisiones documentadas:
//   D-API-V2-1: `hashedKey` usa SHA-256 hex (consistente con ApiToken v1).
//               Argon2/PBKDF2 está sobre-engineered para credenciales que
//               ya son random 256-bit; el coste asimétrico aplica a
//               passwords low-entropy.
//   D-API-V2-2: `scopes` es `text[]` Postgres (no Json) para permitir
//               futuro filtrado server-side por contains (`scopes @> ['read:projects']`).
//   D-API-V2-3: Rate limit es in-memory por instancia. Stateless es
//               aceptable para MVP — si la app se escala horizontal y
//               60req/min × N instancias se vuelve un problema, migrar a
//               Redis/Upstash (deuda registrada).
//   D-API-V2-4: `WebhookDelivery.payload` se persiste para reintentos
//               manuales y forensics. TTL 30 días via cron (no implementado
//               aún; deuda).
//   D-API-V2-5: `WebhookSubscription.failureCount` se incrementa por
//               delivery fallida (todos los reintentos agotados); NO por
//               cada reintento individual. Se resetea al primer 2xx.
// ─────────────────────────────────────────────────────────────

model ApiKey {
  id           String    @id @default(uuid())
  // Etiqueta descriptiva: "Integración SAP S/4HANA producción".
  name         String
  // Primeros 8 chars del key para mostrar en lista sin exponer el resto.
  // El formato canónico del key plano es `sk_<prefix>_<secret>`; el `prefix`
  // aquí es solo el segmento aleatorio (8 chars), no incluye `sk_`.
  prefix       String
  // Hash SHA-256 (hex) del key plano completo. NUNCA almacenamos plaintext.
  hashedKey    String    @unique
  // Array de scopes Postgres-native: ["read:projects","write:tasks"].
  // Ver `src/lib/api/v2-scopes.ts` para el catálogo válido.
  scopes       String[]
  // Workspace owner. Cascade: borrar workspace purga sus keys.
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // Usuario que creó la key (auditoría). SetNull preserva la key si el
  // usuario es eliminado (la integración sigue funcionando).
  createdById  String?
  createdBy    User?     @relation("ApiKeyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastUsedAt   DateTime?
  expiresAt    DateTime?
  revokedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([prefix])
  @@index([revokedAt])
}

model WebhookSubscription {
  id             String    @id @default(uuid())
  workspaceId    String
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  // URL https del receptor. Validación http(s) en server action.
  url            String
  // Secret hex 32 bytes. Usado por dispatcher para HMAC SHA-256 sobre body.
  secret         String
  // Array de eventTypes Postgres-native:
  // ["task.created","risk.high_severity","project.status_changed"].
  events         String[]
  active         Boolean   @default(true)
  lastDeliveryAt DateTime?
  // Counter de fallos consecutivos. Resetea a 0 con primer 2xx. Si llega
  // a 10, dispatcher marca `active=false` automáticamente.
  failureCount   Int       @default(0)
  // Usuario creador (auditoría). SetNull para preservar histórico.
  createdById    String?
  createdBy      User?     @relation("WebhookSubscriptionCreator", fields: [createdById], references: [id], onDelete: SetNull)

  deliveries WebhookDelivery[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([active])
}

model WebhookDelivery {
  id             String              @id @default(uuid())
  subscriptionId String
  subscription   WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  // Tipo de evento que disparó el delivery.
  event          String
  // Payload JSON completo enviado al receptor. Permite re-emisión manual
  // desde la UI sin tener que reconstruir el snapshot.
  payload        Json
  // HTTP status devuelto por el receptor (null si timeout/red).
  responseStatus Int?
  // Body de respuesta (truncado a ~2KB en el dispatcher).
  responseBody   String?
  attemptedAt    DateTime            @default(now())
  // Cuántos reintentos llevamos para este delivery (0 = primer intento).
  retryCount     Int                 @default(0)

  @@index([subscriptionId, attemptedAt])
  @@index([event])
}

// ─────────────────────────────────────────────────────────────
// Módulo Docs / Wikis (Ola P2 · Equipo P2-5)
//
// Editor de documentos markdown con tree jerárquico (Doc.parentId), opcional-
// mente vinculados a un Project o Task. Cada save crea una `DocVersion` para
// permitir restaurar versiones anteriores ("time machine" de doc).
//
// Decisiones documentadas:
//   D-DOC-1: `content` es markdown crudo en TEXT (sin parsing en BD). El
//            render a HTML corre del lado cliente con regex propia
//            (`renderMarkdown`) — evita instalar `marked`/`remark`.
//   D-DOC-2: Soft-delete via `isArchived` en lugar de cascada destructiva.
//            Permite "papelera" y restore. Hard-delete no se expone en MVP.
//   D-DOC-3: `parentId` SetNull en lugar de Cascade — al borrar el doc
//            padre los hijos quedan en raíz, no se pierden. Decisión
//            paralela a Goal.parentId (ver D-OKR-*).
//   D-DOC-4: Se versiona en cada `updateDoc` (no debouncing en BD). El
//            cliente debounce 1s antes de llamar la action; aún así, dos
//            saves rápidos generan dos versions. La página de versiones
//            permite collapsar duplicados visualmente si es ruido.
//   D-DOC-5: `position Float` para reordering dentro del mismo nivel
//            (fractional indexing como en Task / KeyResult).
// ─────────────────────────────────────────────────────────────

model Doc {
  id      String @id @default(uuid())
  title   String
  // Markdown crudo. Validado en server action: ≤ 200 KB.
  content String @db.Text

  // R4-D · DocSpace co-edit · Snapshot binario del documento Yjs (CRDT).
  // Persiste el state vector + document encoded vía `Y.encodeStateAsUpdate`.
  // Nullable: docs legacy o creados sin co-edit funcionan con sólo `content`.
  // El editor colaborativo hace lazy-init de Yjs desde `content` (markdown)
  // si `contentYjs` es null. Tamaño esperado < 2 MB; serializado bytea en
  // PostgreSQL. Ver `docs/features/realtime-coedit.md`.
  contentYjs Bytes?

  // Tree jerárquico — null ⇒ doc raíz.
  parentId String?
  parent   Doc?    @relation("DocHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Doc[]   @relation("DocHierarchy")
  // Orden visual dentro del mismo nivel (fractional indexing).
  position Float   @default(1)

  // Vinculación opcional a Project / Task. SetNull preserva histórico.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Metadata de autoría. `authorId` = creador original (no se cambia).
  // `lastEditorId` = último que pasó por updateDoc (puede ser null si
  // todavía no se ha editado tras crear).
  authorId     String
  author       User    @relation("DocAuthor", fields: [authorId], references: [id])
  lastEditorId String?
  lastEditor   User?   @relation("DocLastEditor", fields: [lastEditorId], references: [id])

  // Soft-archive (D-DOC-2) y publicación pública (futuro: shared link sin
  // sesión; en MVP `isPublic` queda como flag UI sin gating real).
  isArchived Boolean @default(false)
  isPublic   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions DocVersion[]

  @@index([parentId, position])
  @@index([projectId])
  @@index([taskId])
  @@index([isArchived])
}

model DocVersion {
  id String @id @default(uuid())

  docId String
  doc   Doc    @relation(fields: [docId], references: [id], onDelete: Cascade)

  // Snapshot del contenido al momento de la versión.
  content String @db.Text

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  // Etiqueta opcional capturada en la UI ("antes de revisión técnica",
  // "post-feedback Edwin", …).
  changeNote String?

  createdAt DateTime @default(now())

  @@index([docId, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────
// Módulo Audit Log (Ola P3 · Equipo P3-2)
//
// Registro centralizado de eventos críticos del sistema (cambios de tareas,
// dependencias, baselines, proyectos, accesos de usuario, imports/exports,
// permisos…). Pieza obligatoria para compliance ITIL (gestión de cambios)
// y SOC2 (auditoría de accesos y modificaciones).
//
// Decisiones de diseño:
//   - `action` es un `String` (no enum) para permitir extender el catálogo
//     sin migración de schema. La validación se hace en zod (capa app).
//   - `before` / `after` son `Json?` para guardar snapshots ligeros pre/post
//     cambio. Los callers deben recortar campos sensibles (passwords, tokens)
//     antes de pasarlos al helper.
//   - `actorId` es nullable: hay eventos que ocurren sin actor identificable
//     (cron jobs, system events, login fallido). La relación inversa usa
//     `onDelete: SetNull` para preservar el log aún si se borra el usuario.
//   - Sin `updatedAt`: los eventos son inmutables una vez creados (append-only).
//   - Retention: 90 días por default. La limpieza se ejecuta vía
//     `purgeOldAuditEvents` (server action manual; en una fase futura
//     se moverá a cron job).
// ─────────────────────────────────────────────────────────────

model AuditEvent {
  id String @id @default(uuid())

  // Actor que originó el evento. Nullable para system events / login fallido.
  // SetNull para conservar el evento si el usuario es eliminado (compliance).
  actorId String?
  actor   User?   @relation("AuditEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  // Verb namespaced del evento (ej. "task.created", "user.login",
  // "permission.granted"). Validado vs catálogo `KNOWN_AUDIT_ACTIONS` en
  // capa app — no se restringe a enum para permitir extensión sin migración.
  action String

  // Tipo y id de la entidad afectada. `entityType` ∈ {task, project, user,
  // dependency, baseline, permission, import, export, …}. `entityId` es
  // nullable porque algunos eventos son globales (login, export sin id).
  entityType String
  entityId   String?

  // Snapshots pre/post mutación. JSON nullable: si la acción es de creación
  // sólo aplica `after`; si es delete sólo `before`. Los callers son
  // responsables de excluir campos sensibles antes de loguear.
  before Json?
  after  Json?

  // Contexto de red para forensics. Capturados desde headers de la request
  // (x-forwarded-for, user-agent) por el wrapper `withAudit`. Pueden quedar
  // null si el evento se dispara desde un job interno.
  ipAddress String?
  userAgent String?

  // Metadata libre opcional (ej. razón del cambio, traceId). No reemplaza
  // before/after — sirve para campos que no encajan en el snapshot.
  metadata Json?

  createdAt DateTime @default(now())

  // Índices: consultas típicas son "eventos de un actor" (filtro UI),
  // "eventos sobre una entidad" (drill-down forensic) y orden temporal
  // global desc. createdAt sort:Desc acelera el listado paginado.
  @@index([actorId, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────
// R3.0 Fase 2 · Equipo R3-E · Audit Streaming a SIEM externos
//
// Permite reenviar cada `AuditEvent` persistido a uno o más SIEM
// (Splunk HEC, Datadog Logs API v2 o un webhook genérico HMAC) por
// workspace. El flujo es:
//   1. `recordAuditEvent` persiste la fila en `AuditEvent` (path crítico).
//   2. Side-channel "no bloqueante": `enqueueEvent` en la cola in-memory
//      del engine. Si la cola está llena → drop con warning.
//   3. Un cron (`/api/cron/audit-stream`, default 5 min) llama
//      `flushBatches()` que agrupa por target, formatea con el adapter
//      correspondiente y persiste un `AuditStreamDelivery` por batch.
//   4. Retries exponenciales (1s, 5s, 30s). Tras 3 fallos, marca el
//      delivery como `FAILED` y propaga el último error al target.
//
// Decisión D-R3E-1: cola in-memory (no Redis) — la pérdida en restart
// es aceptable porque el `AuditEvent` ya está persistido y la cola sólo
// es buffer de delivery. P22 endurecerá con Redis si la presión sube.
// Decisión D-R3E-2: open-policy RLS inicial; P18+ endurecerá per-workspace.
// Decisión D-R3E-3: el `secret` HMAC se guarda en plano (es el patrón del
// repo para `WebhookSubscription.secret`). Hardening con KMS queda para R4.
// ─────────────────────────────────────────────────────────────

enum AuditStreamKind {
  SPLUNK
  DATADOG
  GENERIC_WEBHOOK
}

enum AuditStreamDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

model AuditStreamTarget {
  id          String          @id @default(uuid())
  workspaceId String
  kind        AuditStreamKind
  endpoint    String
  secret      String
  batchSize   Int             @default(100)
  enabled     Boolean         @default(true)

  lastDeliveryAt DateTime?
  lastError      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries AuditStreamDelivery[]

  @@index([workspaceId, enabled])
}

model AuditStreamDelivery {
  id        String                    @id @default(uuid())
  targetId  String
  batchId   String
  count     Int
  status    AuditStreamDeliveryStatus @default(PENDING)
  attempt   Int                       @default(0)
  lastError String?

  createdAt   DateTime  @default(now())
  deliveredAt DateTime?

  target AuditStreamTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@index([targetId, status, createdAt(sort: Desc)])
  @@index([batchId])
}

// ─────────────────────────────────────────────────────────────
// Módulo Integraciones externas (Ola P4 · Equipo P4-5)
//
// Soporta tres tipos de integración:
//   - SLACK : webhook outbound a un canal Slack (Block Kit).
//   - TEAMS : webhook outbound a un canal MS Teams (Adaptive Card v1.4).
//   - GITHUB: vincula tareas a issues/PRs (no webhooks inbound en P4).
//
// `config` es JSON libre validado en server action según el `type` (zod
// dispatch). Para SLACK/TEAMS contiene `{ webhookUrl: string, channel? }`;
// para GITHUB contiene `{ defaultRepo?: string, token? }` (token opcional
// para futuras llamadas autenticadas — en P4 sólo guardamos referencia).
//
// `projectId` opcional: integraciones globales del workspace viven con
// `projectId = null` y se disparan para todos los proyectos. Cuando hay
// integración específica del proyecto, ésta se prefiere sobre la global.
// ─────────────────────────────────────────────────────────────

enum IntegrationType {
  SLACK
  TEAMS
  GITHUB
}

model Integration {
  id   String          @id @default(uuid())
  type IntegrationType

  // Etiqueta visible en la UI (ej. "Slack #devops", "Repo principal").
  // Permite distinguir varias integraciones del mismo tipo.
  name String

  // Configuración por tipo. Validada en `validateIntegrationConfig` del
  // server action. Mantener pequeño y sin secretos largos (tokens van
  // cifrados en una iteración futura — P4 los guarda en claro asumiendo
  // que el webhook URL ya es el secreto).
  config Json

  // Toggle global. Cuando `false` los dispatchers son no-op silencioso.
  enabled Boolean @default(true)

  // Anclaje opcional a proyecto. NULL = integración global del workspace.
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, enabled])
  @@index([projectId])
}

// Vínculo de una `Task` a un issue/PR concreto de GitHub. No hay webhooks
// inbound en P4 — esta tabla solo guarda la referencia para poder abrir el
// issue desde el TaskDrawer. `repoFullName` es "owner/repo" (validado con
// regex en server action). `issueNumber` es entero positivo; aplica tanto a
// issues como a PRs (GitHub comparte el namespace numérico).
model TaskGitHubLink {
  id String @id @default(uuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // "owner/repo" (ej. "alejandroeml-su/FollowupGantt").
  repoFullName String

  // Número del issue/PR (positivo). GitHub usa el mismo namespace para
  // ambos, pero etiquetamos con `kind` para que la UI muestre el icono
  // correcto sin tener que llamar a la API.
  issueNumber Int

  // "ISSUE" | "PR". String libre (no enum) para no requerir migración si
  // GitHub introduce nuevos tipos. Validado vs un set conocido en zod.
  kind String @default("ISSUE")

  createdAt DateTime @default(now())

  // Una tarea no puede vincular dos veces el mismo issue del mismo repo.
  @@unique([taskId, repoFullName, issueNumber])
  @@index([taskId])
  @@index([repoFullName, issueNumber])
}

// ─────────────────────────────────────────────────────────────────────
// Wave C-debt-1 · Equipo C-DEBT-1 — Checklists relacionales.
//
// Reemplaza el hack P7-5 (que anexaba el checklist sugerido por IA como
// markdown al `task.description`). Modelo:
//   - `Checklist` agrupa items bajo un `title` opcional y pertenece a una
//     `Task`. Cascade al borrar la tarea.
//   - `ChecklistItem` lleva el texto, flag `done` y metadatos de auditoría
//     (`doneAt`, `doneById`) para reportes futuros (velocity, throughput).
//     `position` es Float para soportar fractional indexing en reorder
//     (ADR-001 · mismo patrón que `Task.position`).
//
// Errores tipados (server actions): `[CHECKLIST_NOT_FOUND]`,
// `[ITEM_NOT_FOUND]`, `[INVALID_INPUT]`, `[FORBIDDEN]`.
// ─────────────────────────────────────────────────────────────────────

model Checklist {
  id        String          @id @default(uuid())
  taskId    String
  task      Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  items     ChecklistItem[]

  @@index([taskId])
}

model ChecklistItem {
  id          String    @id @default(uuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  text        String
  done        Boolean   @default(false)
  position    Float     @default(1)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  doneAt      DateTime?
  doneById    String?

  @@index([checklistId, position])
  @@index([done])
}

// ────────────────────────────────────────────────────────────────────
// Ola P8 · Equipo P8-1 · Resource Management Visual.
//
// Skills + matriz Users × Skills × nivel 1-5. Permite:
//   - Filtrar "available users" en TaskForm por skill + nivel mínimo.
//   - Sugerir reasignaciones en `rebalance.ts` priorizando candidatos
//     con la misma skill primaria del task original.
//   - Reporting cruzado capacidad/skills.
//
// La asociación es M:N estricta (un user puede dominar varias skills,
// una skill la pueden tener varios users). El nivel se fija en la
// fila de la tabla pivote.
// ────────────────────────────────────────────────────────────────────

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String? // "frontend" | "backend" | "design" | "qa" | etc.
  createdAt DateTime @default(now())

  userSkills UserSkill[]
}

model UserSkill {
  userId    String
  skillId   String
  level     Int      @default(3) // 1=novato … 5=experto
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, skillId])
  @@index([skillId])
}

// ─────────────────────────────────────────────────────────────────────
// Wave P8 · Equipo P8-2 · Risk Register + Monte Carlo simulation
// ─────────────────────────────────────────────────────────────────────
//
// Riesgos del proyecto siguiendo PMBOK §11 (Project Risk Management):
//   - Identificación con probability × impact (matriz 5×5).
//   - Score = probability * impact ∈ [1, 25] calculado en app-level
//     (`@/lib/risks/risk-score`). NO se persiste para evitar drift.
//   - Tier (LOW/MEDIUM/HIGH/CRITICAL) derivado del score.
//   - `triggerDelayDays` alimenta la simulación Monte Carlo
//     (`@/lib/risks/monte-carlo`) que reescribe el CPM con delays
//     materializados según `probability/100`.
//
// Decisiones (D-RISK-1 .. D-RISK-3):
//   D-RISK-1 · `score` no se persiste. Si Prisma migra a generated columns
//             se promoverá a campo derivado; por ahora calculado en server
//             actions y al render.
//   D-RISK-2 · `Risk` no se acopla a Tasks específicas en el MVP — el
//             delay se asume sobre el proyecto completo (toda la cadena
//             crítica). Iteración P8.5 introducirá `RiskTaskImpact[]` para
//             segmentar el efecto por sub-cadena.
//   D-RISK-3 · `closedAt` se setea en server action al cambiar status a
//             CLOSED. La transición desde ACCEPTED a CLOSED es válida
//             (riesgo aceptado pero ya no aplicable).

enum RiskStatus {
  OPEN
  MITIGATING
  ACCEPTED
  CLOSED
}

/// Wave R-360 (post-P17) — origen de un Risk para visión 360°:
///   - MANUAL    : creado por un usuario desde la UI (default).
///   - HEURISTIC : promovido desde TaskInsight kind=DELAY_RISK.
///   - BRAIN_AI  : promovido desde Brain Project Manager AI (Wave P14c).
///   - IMPORTED  : creado vía CSV/Excel (Wave P16-B Migration Assistant).
enum RiskSource {
  MANUAL
  HEURISTIC
  BRAIN_AI
  IMPORTED
}

/// Wave R-360 — estado de una Risk Action correctiva (workflow Kanban).
enum RiskActionStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

model Risk {
  id          String  @id @default(uuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?

  // Probability ∈ [1,5] e impact ∈ [1,5] (matriz 5×5 PMBOK).
  probability Int
  impact      Int

  status  RiskStatus @default(OPEN)
  ownerId String?
  owner   User?      @relation("RiskOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  mitigation String?

  // Estimación de duración adicional al CPM si el risk se materializa
  // (días corridos). Alimenta la simulación Monte Carlo.
  triggerDelayDays Int?

  /// Wave P14c (Avante Brain · Project Manager AI) — vínculo opcional con
  /// la tarea específica que origina/contiene el riesgo. Permite el
  /// drill-down "ver tarea" desde el Risk Register y excluir alertas
  /// duplicadas cuando el LLM las re-sugiere.
  ///
  /// `onDelete: SetNull` porque el riesgo es metadata histórica del
  /// proyecto y debe sobrevivir a la eliminación de la task que lo
  /// originó (compliance PMI).
  taskId String?
  task   Task?   @relation("TaskRisks", fields: [taskId], references: [id], onDelete: SetNull)

  /// Wave R-360 — trazabilidad de origen + dedupe.
  /// `source` identifica de dónde nació el riesgo (MANUAL/HEURISTIC/
  /// BRAIN_AI/IMPORTED). `sourceRef` contiene el ID externo (ej.
  /// `taskInsightId` para HEURISTIC, `brainInsightId` para BRAIN_AI)
  /// para evitar promover dos veces el mismo insight.
  source    RiskSource @default(MANUAL)
  sourceRef String?

  detectedAt DateTime  @default(now())
  closedAt   DateTime?

  /// Wave R-360 — acciones correctivas asociadas (one-to-many).
  actions RiskAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
  @@index([probability, impact])
  @@index([taskId])
  @@index([source, sourceRef])
}

/// Wave R-360 — Acción correctiva de un riesgo. Permite gestionar el plan
/// de mitigación con responsable, fecha objetivo y workflow de status.
/// Cada Risk puede tener N RiskActions; visibles desde el panel de gestión
/// de riesgos del proyecto.
model RiskAction {
  id          String           @id @default(uuid())
  riskId      String
  risk        Risk             @relation(fields: [riskId], references: [id], onDelete: Cascade)
  description String
  ownerId     String?
  owner       User?            @relation("RiskActionOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  status      RiskActionStatus @default(PENDING)
  dueDate     DateTime?
  doneAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([riskId, status])
  @@index([ownerId, status])
  @@index([dueDate])
}

// ─────────────────────────────────────────────────────────────────
// Wave P8 · Equipo P8-5 — Calendar sync (Google + Microsoft + ICS).
//
// Decisiones aprobadas:
//   - One-way sync (FollowupGantt → Calendar). En MVP NO leemos eventos
//     externos: evita merge conflicts y reduce rate-limit a Google/MS.
//   - OAuth tokens en raw (text); rotación a KMS/encrypted-at-rest se
//     hará en P9. La superficie es baja porque solo el dueño los ve.
//   - ICS público con token aleatorio (no PII en URL): cualquier client
//     (Apple Calendar, Thunderbird, ICS-aware fallback) puede subscribir
//     al feed sin OAuth. Token rotativo por usuario.
//   - `CalendarEvent` actúa como ledger de auditoría: una fila por cada
//     item enviado al provider. Con `externalEventId` la siguiente sync
//     es idempotente (PATCH en vez de POST si ya existe).
//
// Consumidores: `sync-engine.ts`, `ics-export.ts`, cron `/api/cron/calendar-sync`.
// ─────────────────────────────────────────────────────────────────

// ─────────────────────────────────────────────────────────────────
// Wave P18-A · Quality Inspections + Defect Tracking (PMI 100%)
//
// Cierra el gap de PMBOK 6/7 "Quality Management": procesos formales de
// inspección/auditoría de entregables + tracking de defectos detectados.
// Sin estos artefactos visibles, Sync mantenía PMI en ~98% (compliance
// "demo-ready"). Esta wave sube a 100% riguroso.
// ─────────────────────────────────────────────────────────────────

enum InspectionType {
  CODE_REVIEW
  TEST_REVIEW
  DESIGN_REVIEW
  AUDIT
  WALKTHROUGH
}

enum InspectionResult {
  PENDING
  PASS
  PASS_WITH_DEFECTS
  FAIL
}

model QualityInspection {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Tarea o entregable bajo inspección (opcional).
  taskId String?
  task   Task?   @relation("TaskInspections", fields: [taskId], references: [id], onDelete: SetNull)

  type   InspectionType
  result InspectionResult @default(PENDING)

  inspectorId String?
  inspector   User?   @relation("InspectionInspector", fields: [inspectorId], references: [id], onDelete: SetNull)

  scheduledAt DateTime?
  completedAt DateTime?

  /// Array libre [{ text, done, notes? }] validado en server action.
  checklist Json?
  summary   String?

  defects Defect[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, result])
  @@index([taskId])
  @@index([inspectorId])
}

enum DefectSeverity {
  CRITICAL
  MAJOR
  MINOR
  TRIVIAL
}

enum DefectStatus {
  OPEN
  IN_REVIEW
  FIXED
  WONT_FIX
  DUPLICATE
}

model Defect {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  inspectionId String?
  inspection   QualityInspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)

  taskId String?
  task   Task?   @relation("TaskDefects", fields: [taskId], references: [id], onDelete: SetNull)

  title       String
  description String?
  severity    DefectSeverity @default(MAJOR)
  status      DefectStatus   @default(OPEN)

  ownerId String?
  owner   User?   @relation("DefectOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  reporterId String?
  reporter   User?   @relation("DefectReporter", fields: [reporterId], references: [id], onDelete: SetNull)

  resolvedAt DateTime?
  resolution String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status, severity])
  @@index([inspectionId])
  @@index([taskId])
  @@index([ownerId, status])
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  ICS
}

model CalendarConnection {
  id       String           @id @default(uuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider CalendarProvider

  // OAuth credentials (raw en MVP — encrypt-at-rest queda como deuda P9).
  // ICS provider deja estos null y solo usa `icsToken`.
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?

  // Calendar id en el provider (Google "primary" / MS calendar GUID).
  externalId String?

  // Toggles granulares: el usuario puede sincronizar solo milestones,
  // o además sus deadlines, o también boundaries de sprints.
  syncEnabled    Boolean @default(true)
  syncMilestones Boolean @default(true)
  syncDeadlines  Boolean @default(true)
  syncSprints    Boolean @default(false)

  // Token rotativo para feed ICS público. Único por seguridad: si el
  // usuario sospecha que el feed se filtró, regenera el token y el
  // anterior queda inutilizable.
  icsToken String? @unique

  lastSyncAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  events CalendarEvent[]

  // Un usuario solo puede tener una conexión por provider (multi-cuenta
  // Google se modelaría en una tabla separada en el futuro).
  @@unique([userId, provider])
  @@index([userId])
}

model CalendarEvent {
  id           String             @id @default(uuid())
  connectionId String
  connection   CalendarConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  // Id devuelto por Google/MS (null para ICS — el cliente externo arma
  // su propio uid desde el VEVENT). Permite upsert idempotente.
  externalEventId String?

  // Referencia opcional al objeto interno. Para milestones/deadlines es
  // un Task.id; para sprints es un Sprint.id. NO es FK porque Task y
  // Sprint son entidades distintas y queremos audit-log aún si se borra
  // el origen.
  taskId String?

  type     String // "milestone" | "deadline" | "sprint"
  title    String
  startsAt DateTime
  endsAt   DateTime
  syncedAt DateTime @default(now())

  @@index([connectionId, type])
  @@index([taskId])
}

// ─────────────────────────────────────────────────────────────────────
// Ola P8 · Equipo P8-3 · Cost Management
//
// Modelo de gastos (Expense) + tipos de cambio (CurrencyRate). Los gastos
// se someten en su moneda original y se cachea su equivalente en USD
// (`amountUsd`) usando la última `CurrencyRate` disponible en el momento
// de la submisión. Esto permite reporting consolidado sin tener que
// recalcular conversiones a la hora de leer.
//
// Decisiones autónomas (P8-3):
//   D-COST-1: Decimal(12,2) para amounts (suficiente para ~9.999B sin
//             pérdida; > USD para 99% de proyectos internos Avante).
//   D-COST-2: `receiptUrl` es placeholder hasta que P8-4 implemente
//             Storage uploads (Supabase Storage signed URLs).
//   D-COST-3: `incurredAt` es la fecha de la transacción real (no del
//             registro), separada de `createdAt`. Se usa para reporting
//             temporal y allocation a sprints/phases por ventana.
//   D-COST-4: Status REIMBURSED es terminal post-APPROVED y solo lo setea
//             un admin/finance manualmente (sin cron en MVP).
// ─────────────────────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

model Expense {
  id String @id @default(uuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  submittedById String
  submittedBy   User   @relation("ExpenseSubmitter", fields: [submittedById], references: [id], onDelete: Restrict)

  description String
  amount      Decimal @db.Decimal(12, 2)
  currency    String // ISO 4217: USD/MXN/EUR/...

  // Snapshot de conversión a USD calculado al submit/approve usando la
  // `CurrencyRate` más reciente. Nullable porque al crear DRAFT la
  // conversión puede deferirse hasta SUBMITTED si no hay rates aún.
  amountUsd Decimal? @db.Decimal(12, 2)

  // Placeholder para futuro Storage upload (Ola P8-4). En P8-3 aceptamos
  // URLs externas (Drive, S3 público) o queda NULL.
  receiptUrl String?

  status         ExpenseStatus @default(DRAFT)
  approvedById   String?
  approvedBy     User?         @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt     DateTime?
  reimbursedAt   DateTime?
  rejectedReason String?
  incurredAt     DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
  @@index([submittedById, createdAt])
  @@index([incurredAt])
}

model CurrencyRate {
  id        String   @id @default(uuid())
  base      String // "USD" — moneda canónica del repositorio
  quote     String // "MXN", "EUR", ... ISO 4217
  rate      Decimal  @db.Decimal(18, 8)
  source    String // "ecb" | "exchangerate-api" | "manual"
  fetchedAt DateTime @default(now())

  @@unique([base, quote, fetchedAt])
  @@index([base, quote, fetchedAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────
// Wave P10 · Enterprise Portfolio (kickoff sketch — sin migración aún)
// ─────────────────────────────────────────────────────────────

/// Wave P10 (HU-10.2) — Disponibilidad por usuario (vacaciones, días reducidos).
/// Reutiliza `WorkCalendar`+`Holiday` existentes (Ola P1.5) como base; este
/// modelo agrega excepciones individuales que el motor CPM y la capacity de
/// sprint deben restar a la jornada estándar.
model UserAvailability {
  id                  String             @id @default(uuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  startDate           DateTime
  endDate             DateTime
  reason              AvailabilityReason
  /// Si null → bloque completo (vacación). Si 0-100 → jornada reducida.
  reducedHoursPercent Int?
  notes               String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([userId, startDate, endDate])
}

enum AvailabilityReason {
  VACATION
  SICK
  TRAINING
  REDUCED_HOURS
  OTHER
}

/// Wave P10 (HU-10.4) — Dependencias entre tasks de proyectos distintos.
/// El modelo `Dependency` actual (intra-project) NO se modifica para evitar
/// regresión en CPM/Gantt. Esta tabla nueva es leída por el motor de
/// portfolio para grafos cross-project + alertas de propagación.
model CrossProjectDependency {
  id           String         @id @default(uuid())
  sourceTaskId String
  sourceTask   Task           @relation("CrossDepSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTaskId String
  targetTask   Task           @relation("CrossDepTarget", fields: [targetTaskId], references: [id], onDelete: Cascade)
  type         DependencyType
  lagDays      Int            @default(0)
  notes        String?
  createdById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([sourceTaskId, targetTaskId])
  @@index([sourceTaskId])
  @@index([targetTaskId])
}

/// Wave P10 (HU-10.7) — Snapshot semanal de allocation cross-project por
/// usuario. Computado por cron Vercel `0 2 * * *` (HU-10.7 B2.1) para
/// evitar N+1 al pintar el heatmap. Refresh on-demand via server action
/// cuando un PM mueve assignments.
model ResourceAllocationSnapshot {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Lunes ISO de la semana (UTC midnight).
  weekStart   DateTime
  /// Total horas planeadas esa semana sumando todos los proyectos.
  totalHours  Float
  /// Detalle por proyecto: `[{projectId, projectName, hours, percent}]`.
  /// JSON evita crear tabla join solo para snapshot read-only.
  allocations Json
  computedAt  DateTime @default(now())

  @@unique([userId, weekStart])
  @@index([weekStart])
}

// ─────────────────────────────────────────────────────────────
// Wave P11-PMI · PMBOK 6/7 compliance modules
// ─────────────────────────────────────────────────────────────

/// Wave P11-PMI (HU-12.2) — Stakeholder Register PMBOK.
/// Mantiene el inventario de stakeholders del proyecto con su matriz
/// de poder/interés/influencia para diseñar engagement strategies.
model Stakeholder {
  id                 String               @id @default(uuid())
  projectId          String
  project            Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name               String
  organization       String?
  email              String?
  /// Rol PMBOK: Sponsor / Customer / Team / Vendor / Regulator / Other
  role               String
  /// Matriz poder/interés/influencia.
  power              StakeholderLevel     @default(MEDIUM)
  interest           StakeholderLevel     @default(MEDIUM)
  influence          StakeholderInfluence @default(NEUTRAL)
  expectations       String?
  /// Estrategia de engagement: Manage Closely / Keep Satisfied /
  /// Keep Informed / Monitor.
  engagementStrategy String?
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([projectId])
  @@index([projectId, power, interest])
}

enum StakeholderLevel {
  LOW
  MEDIUM
  HIGH
}

enum StakeholderInfluence {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

/// Wave P11-PMI (HU-12.3) — Change Request workflow (CCB).
/// PMBOK Integration Management · Perform Integrated Change Control.
/// Captura solicitudes de cambio de scope/schedule/cost con análisis
/// de impacto y workflow de aprobación.
model ChangeRequest {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title       String
  description String
  rationale   String?

  requestedById String
  requestedBy   User   @relation("ChangeRequestRequester", fields: [requestedById], references: [id], onDelete: Restrict)

  /// Análisis de impacto en las 4 dimensiones triple-restricción + calidad.
  impactScope                ChangeImpactLevel @default(NONE)
  impactSchedule             ChangeImpactLevel @default(NONE)
  impactCost                 ChangeImpactLevel @default(NONE)
  impactQuality              ChangeImpactLevel @default(NONE)
  estimatedCostDelta         Decimal?          @db.Decimal(14, 2)
  estimatedScheduleDeltaDays Int?

  status        ChangeRequestStatus @default(SUBMITTED)
  decidedAt     DateTime?
  decidedById   String?
  decidedBy     User?               @relation("ChangeRequestApprover", fields: [decidedById], references: [id], onDelete: SetNull)
  decisionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
  @@index([requestedById])
}

enum ChangeRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  DEFERRED
  IMPLEMENTED
}

enum ChangeImpactLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

/// Wave P11-PMI (HU-12.4) — Procurement Management · Vendor.
/// Catálogo de proveedores reusable cross-project.
model Vendor {
  id            String     @id @default(uuid())
  workspaceId   String?
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  name          String
  contactPerson String?
  contactEmail  String?
  taxId         String?
  notes         String?
  isActive      Boolean    @default(true)

  contracts      Contract[]
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, isActive])
}

/// Wave P11-PMI (HU-12.4) — Procurement Management · Contract.
/// Tipos PMBOK: FFP, CPFF, T&M, CR.
model Contract {
  id           String         @id @default(uuid())
  vendorId     String
  vendor       Vendor         @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title        String
  contractType ContractType   @default(FFP)
  totalValue   Decimal?       @db.Decimal(14, 2)
  currency     String         @default("USD")
  startDate    DateTime?
  endDate      DateTime?
  status       ContractStatus @default(DRAFT)
  description  String?
  documentUrl  String?

  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, status])
  @@index([projectId])
}

enum ContractType {
  FFP // Firm Fixed Price
  CPFF // Cost Plus Fixed Fee
  TM // Time and Materials
  CR // Cost Reimbursable
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  TERMINATED
}

/// Wave P11-PMI (HU-12.4) — Procurement Management · Purchase Order.
/// Order placed against Vendor (con o sin Contract paraguas).
model PurchaseOrder {
  id                 String    @id @default(uuid())
  vendorId           String
  vendor             Vendor    @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  contractId         String?
  contract           Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  projectId          String?
  project            Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  poNumber           String    @unique
  description        String
  amount             Decimal   @db.Decimal(14, 2)
  currency           String    @default("USD")
  issuedAt           DateTime  @default(now())
  expectedDeliveryAt DateTime?
  receivedAt         DateTime?
  status             POStatus  @default(DRAFT)
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vendorId, status])
  @@index([projectId])
  @@index([contractId])
}

enum POStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

// ═════════════════════════════════════════════════════════════════════
// Wave P12 · Final Compliance (Scrum 100% + PMI dashboards visibles)
// ═════════════════════════════════════════════════════════════════════

/// Wave P12 (Scrum 100%) — Impediments tracker.
/// Bloqueos detectados en el Daily Scrum o cualquier ceremonia que
/// impiden al equipo avanzar. Property del Scrum Master, escalables
/// fuera del equipo cuando exceden su capacidad de resolución.
model Impediment {
  id       String @id @default(uuid())
  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  raisedById String?
  raisedBy   User?   @relation("ImpedimentRaiser", fields: [raisedById], references: [id], onDelete: SetNull)
  ownerId    String?
  owner      User?   @relation("ImpedimentOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  title           String
  description     String?
  severity        ImpedimentSeverity @default(MEDIUM)
  status          ImpedimentStatus   @default(OPEN)
  raisedAt        DateTime           @default(now())
  resolvedAt      DateTime?
  resolutionNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sprintId, status])
}

enum ImpedimentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ImpedimentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
}

/// Wave P12 (Scrum 100%) — Daily Scrum session.
/// Captura del sync diario en formato 3 preguntas (Did / Will do /
/// Blockers). Permite al PO/SM revisar tendencias y picos de blockers.
model DailyScrum {
  id       String @id @default(uuid())
  sprintId String
  sprint   Sprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  facilitatorId String?
  facilitator   User?   @relation("DailyScrumFacilitator", fields: [facilitatorId], references: [id], onDelete: SetNull)

  scheduledFor DateTime @default(now())
  /// Shape: { entries: [{ userId, did: string, willDo: string, blockers: string }] }
  data         Json?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sprintId, scheduledFor])
}

/// Wave P12 (Scrum 100%) — Improvement Items (Retro Action Items
/// con tracking cross-sprint). Permite saber si las acciones del
/// retro de Sprint N realmente se cierran en N+1, N+2... métrica
/// clave de madurez ágil.
model ImprovementItem {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  retrospectiveId String?
  retrospective   Retrospective? @relation(fields: [retrospectiveId], references: [id], onDelete: SetNull)

  ownerId String?
  owner   User?   @relation("ImprovementOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  title       String
  description String?
  status      ImprovementStatus @default(OPEN)
  dueDate     DateTime?
  closedAt    DateTime?
  closeNotes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
}

enum ImprovementStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

/// Wave P12 (PMI 100%) — Lessons Learned repository.
/// Repositorio centralizado de lecciones aprendidas para
/// proceso de mejora continua organizacional (PMBOK 7 — Knowledge
/// Management). Visibilidad escalable: PROJECT → WORKSPACE → ORG.
model LessonLearned {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  capturedById String?
  capturedBy   User?   @relation("LessonCapturer", fields: [capturedById], references: [id], onDelete: SetNull)

  title          String
  category       LessonCategory   @default(PROCESS)
  context        String
  whatHappened   String
  rootCause      String?
  recommendation String
  /// Tags / áreas / fases relevantes (string libre, separable por comas).
  appliesTo      String?
  visibility     LessonVisibility @default(WORKSPACE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([category])
  @@index([visibility])
}

enum LessonCategory {
  PROCESS
  TECHNICAL
  PEOPLE
  TOOLS
  RISK
  QUALITY
  COMMUNICATIONS
  OTHER
}

enum LessonVisibility {
  PROJECT
  WORKSPACE
  ORG
}

/// Wave P12 (PMI 100%) — EVM Snapshots para S-curve dashboard.
/// Series temporales de PV/EV/AC permiten visualizar la evolución
/// del proyecto vs baseline (curva S clásica de PMBOK · Earned
/// Value Management).
model EVMSnapshot {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  snapshotDate         DateTime @default(now())
  /// PV = Planned Value (BCWS — Budgeted Cost of Work Scheduled).
  plannedValue         Decimal  @db.Decimal(14, 2)
  /// EV = Earned Value (BCWP — Budgeted Cost of Work Performed).
  earnedValue          Decimal  @db.Decimal(14, 2)
  /// AC = Actual Cost (ACWP — Actual Cost of Work Performed).
  actualCost           Decimal  @db.Decimal(14, 2)
  /// BAC snapshotted para tracking de cambios al budget.
  budgetAtCompletion   Decimal? @db.Decimal(14, 2)
  /// CPI = EV / AC.
  cpi                  Float?
  /// SPI = EV / PV.
  spi                  Float?
  /// EAC = BAC / CPI (estimación al cierre).
  estimateAtCompletion Decimal? @db.Decimal(14, 2)
  /// VAC = BAC - EAC.
  varianceAtCompletion Decimal? @db.Decimal(14, 2)
  notes                String?

  createdAt DateTime @default(now())

  @@index([projectId, snapshotDate])
}

// ═════════════════════════════════════════════════════════════════════
// Wave P15 (Brain Project Insights AI ampliado)
// ═════════════════════════════════════════════════════════════════════

/// Wave P15 — Insight generado por Avante Brain AI sobre un proyecto.
///
/// Cubre 3 categorías:
///   - FORECAST: predicción cuantitativa (sprint completion, ROI, milestone)
///   - RECOMMENDATION: acción sugerida (re-allocation, scope cut, dep unblock)
///   - ANOMALY: alerta detectada (stale tasks, SP outliers, escalation needed)
///
/// El usuario puede `Aplicar` (status → APPLIED · puede crear Risk/Task/
/// Improvement según `relatedAction`) o `Descartar` (status → DISMISSED).
/// Los aplicados/descartados se excluyen de futuras generaciones para no
/// duplicar (mismo dedupe que Risk Register · Wave P14c).
model BrainInsight {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  kind     BrainInsightKind
  title    String
  body     String
  severity BrainInsightSeverity @default(MEDIUM)

  /// Acción sugerida estructurada (opcional). Shape:
  ///   { type: 'create_risk' | 'create_improvement' | 'create_task' | 'none',
  ///     payload: object }
  relatedAction Json?

  status      BrainInsightStatus @default(NEW)
  appliedAt   DateTime?
  dismissedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, kind, status])
  @@index([createdAt])
}

enum BrainInsightKind {
  FORECAST
  RECOMMENDATION
  ANOMALY
}

enum BrainInsightSeverity {
  LOW
  MEDIUM
  HIGH
}

enum BrainInsightStatus {
  NEW
  APPLIED
  DISMISSED
}
// ─────────────────────────────────────────────────────────────
// Wave P17-C · Self-Service Admin — GlobalTemplate
//
// Catálogo central de plantillas que SUPER_ADMIN puede crear/editar y
// clonar a workspaces concretos. Tipo de plantilla (`kind`) determina
// el shape del payload (validado en server action via zod).
//
// `workspaceId` NULL == plantilla global (visible a todos los workspaces).
// Cuando se "Aplica a workspace X", se clona el row con `workspaceId=X`
// en lugar de mutarse — el catálogo global queda intacto.
// ─────────────────────────────────────────────────────────────

enum GlobalTemplateKind {
  PROJECT
  WBS
  DOR_DOD
  COMM_PLAN
}

model GlobalTemplate {
  id   String             @id @default(uuid())
  name String
  kind GlobalTemplateKind

  /// Shape libre — validado en `lib/actions/admin-templates.ts` por kind.
  payload Json

  /// NULL = plantilla global (catálogo SUPER_ADMIN). Set = clonada/atada
  /// a un workspace específico.
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// FK al SUPER_ADMIN que la creó. SetNull para conservar la plantilla
  /// si el creador es eliminado del sistema.
  createdById String?
  createdBy   User?   @relation("GlobalTemplateCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kind])
  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────
// Wave P19-D · Brain Strategist Persistence
//
// Persiste los insights cross-project que hoy son ephemeral en
// `src/lib/brain/strategist/actions.ts`. Cada `StrategistReport`
// se explota en N rows (uno por insight) para permitir filtrado,
// historial temporal, ACK/Resolve y comparación mes-a-mes.
//
// `workspaceId` NULL = scope global (todos los proyectos visibles
// al actor); set = scope acotado al workspace. Mantenemos string
// (no FK) porque el insight nace de un análisis cross-workspace y
// los detectores ya operan con el workspace-scope efectivo del
// caller; se valida en server actions, no a nivel BD.
// ─────────────────────────────────────────────────────────────

enum StrategistInsightKind {
  RESOURCE_CONTENTION
  DEPENDENCY_CONFLICT
  REUSABLE_LESSON
  PREDICTIVE_SCENARIO
  BALANCE_SUGGESTION
}

enum StrategistInsightSeverity {
  HIGH
  MEDIUM
  LOW
}

model BrainStrategistInsight {
  id          String                    @id @default(uuid())
  workspaceId String?
  kind        StrategistInsightKind
  severity    StrategistInsightSeverity

  /// Snapshot serializable del insight original (depende de `kind`):
  ///   resource_contention: { userId, userName, overlapDays, projects[] }
  ///   dependency_conflict: { predecessor, successor, gapDays }
  ///   reusable_lesson:     { sourceProject, category, title, applicableProjects[] }
  ///   predictive_scenario: { sourceTaskId, delayDays, affected[] }
  ///   balance_suggestion:  { userId, kind, message, metrics }
  payload Json

  /// Resumen humano (1-2 líneas) usado en el historial/timeline UI.
  summary String?

  /// Status de seguimiento: NEW | ACKNOWLEDGED | RESOLVED | DISMISSED.
  /// Se modela como String (no enum) para permitir extender el workflow
  /// sin migración destructiva — la validación vive en zod (server actions).
  status String @default("NEW")

  ackById String?
  ackBy   User?   @relation("StrategistInsightAck", fields: [ackById], references: [id], onDelete: SetNull)
  ackedAt DateTime?

  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, kind, status])
  @@index([severity, createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────
// R3.0 · Fase 2 · SSO / SAML 2.0 (R3-D)
// ─────────────────────────────────────────────────────────────

/// R3.0 · Fase 2 — Tipo de IdP. Sólo SAML 2.0 en esta iteración.
enum SsoProviderKind {
  SAML
}

model SsoProvider {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  name String
  kind SsoProviderKind @default(SAML)
  entityId String
  ssoUrl String
  x509Cert String @db.Text
  attributeMap Json
  enabled Boolean @default(true)

  links SsoUserLink[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, entityId])
  @@index([workspaceId])
  @@index([enabled])
}

model SsoUserLink {
  id         String      @id @default(uuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerId String
  provider   SsoProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  externalId String
  lastLoginAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, externalId])
  @@unique([providerId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// R3.0-F · Data Retention Policies (Wave R3 Fase 2 — Compliance)
// ─────────────────────────────────────────────────────────────

enum RetentionDomain {
  AUDIT_LOG
  SESSION
  NOTIFICATION
  BRAIN_INSIGHT
}

enum RetentionPurgeStatus {
  RUNNING
  SUCCESS
  FAILED
}

model RetentionPolicy {
  id          String          @id @default(uuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  domain      RetentionDomain
  retainDays  Int
  enabled     Boolean         @default(true)

  lastPurgeAt    DateTime?
  lastPurgeCount Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runs RetentionPurgeRun[]

  @@unique([workspaceId, domain])
  @@index([workspaceId])
  @@index([enabled])
}

model RetentionPurgeRun {
  id          String               @id @default(uuid())
  policyId    String
  policy      RetentionPolicy      @relation(fields: [policyId], references: [id], onDelete: Cascade)
  startedAt   DateTime             @default(now())
  completedAt DateTime?
  deletedCount Int                 @default(0)
  status      RetentionPurgeStatus @default(RUNNING)
  errorMessage String?

  @@index([policyId, startedAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────
// Wave P20-C · Brain Auto-Pilot
//
// Persiste cada apply de un AutoPilotProposal junto con su snapshot
// completo y las ops inversas necesarias para revertirlo. El snapshot
// permite trazar el "qué se aplicó" sin depender de los detectores
// (heuristícas evolucionarán); las ops inversas son la única fuente
// de verdad para el rollback.
//
// Workspace cascade: archivar el workspace borra su historial de
// runs — no hay riesgo regulatorio porque la información viva en
// AuditEvent también (`auto_pilot.proposal_applied`).
// ─────────────────────────────────────────────────────────────

model AutoPilotRun {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  kind    String
  summary String

  /// Snapshot completo del `AutoPilotProposal` aplicado (incluye
  /// `applyOps`, `preview` y `rationale`).
  proposalSnapshot Json

  appliedById String?
  appliedBy   User?   @relation("AutoPilotRunAppliedBy", fields: [appliedById], references: [id], onDelete: SetNull)
  appliedAt   DateTime @default(now())

  rolledBackAt DateTime?
  /// Lista de `AutoPilotOp` inversas (mismo shape JSON-serializable).
  rollbackOps  Json?

  @@index([workspaceId, appliedAt(sort: Desc)])
}
