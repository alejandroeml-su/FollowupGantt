# ─────────────────────────────────────────────────────────────
# FollowupGantt · Variables de entorno (plantilla)
# Copiar a .env.local y rellenar. NO commitear .env.local.
# ─────────────────────────────────────────────────────────────

# Base de datos (Supabase / Postgres con pool=1)
DATABASE_URL="postgresql://user:password@host:5432/db?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://user:password@host:5432/db"

# Supabase (opcional, si se usa el SDK)
# Ola P6 · Realtime: requeridas para presence/broadcast en navegador.
# Si quedan vacías, los hooks de `src/lib/realtime/*` degradan a no-op
# (la app no rompe, sólo no hay colaboración en vivo).
# Habilitar Realtime en Supabase Dashboard → Settings → API → Realtime.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ── Notificaciones por correo ─────────────────────────────────
# El provider (`src/lib/email/provider.ts`) selecciona automáticamente
# el primer adapter disponible: SMTP > SendGrid > Resend > none.
#
# Recomendado en Avante (M365 corporativo): SMTP genérico contra
# `smtp.office365.com:587` con el buzón `proyecto@complejoavante.com`.
# Ventaja: emails salen nativos de @complejoavante.com con SPF/DKIM
# del tenant (sin "via sendgrid.net" en Gmail).
#
# Caveat M365: si el tenant tiene "SmtpClientAuthentication disabled"
# (default en tenants nuevos), nodemailer recibirá `535 5.7.139` y
# el provider degrada al siguiente adapter. Pedir al admin que habilite
# SMTP AUTH para el buzón remitente, o usar SendGrid Single Sender.
SMTP_HOST="smtp.office365.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="proyecto@complejoavante.com"
SMTP_PASSWORD=""

# Fallback A: SendGrid Single Sender (no requiere DNS — el usuario
# verifica una dirección concreta en https://app.sendgrid.com/settings/sender_auth).
# Activo si SMTP_* no están configuradas.
SENDGRID_API_KEY=""

# Fallback B: Resend (requiere dominio verificado — bloqueado mientras
# no haya acceso DNS de iPower). Dashboard: https://resend.com/api-keys
RESEND_API_KEY=""

# Remitente visible en el From de los correos. Coincidir con SMTP_USER
# o con el Single Sender verificado en SendGrid.
EMAIL_FROM="FollowupGantt <proyecto@complejoavante.com>"

# ── URL base pública (usada en enlaces de correo) ─────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Observability (C2 · Sentry) ───────────────────────────────
# DSN del proyecto Sentry (server runtime). Deshabilitado si vacío.
SENTRY_DSN=
# Mismo DSN expuesto al bundle del navegador. Puede ser igual o un DSN
# separado si Edwin prefiere segmentar errores client/server en Sentry.
NEXT_PUBLIC_SENTRY_DSN=
# Token con scope `project:write` para subir source-maps en CI/Vercel.
# NUNCA lo pongas en .env.local committeable; configurarlo sólo en
# Vercel Environment Variables (Production + Preview).
SENTRY_AUTH_TOKEN=
# Slug de la organización Sentry (visible en URLs del dashboard).
SENTRY_ORG=
# Slug del proyecto Sentry.
SENTRY_PROJECT=

# ── Wave P7 · AI / LLM adapter ────────────────────────────────
# El adapter `src/lib/ai/llm/*` consume Anthropic primario y OpenAI
# como fallback. Si ambas vacías o `LLM_ENABLED=false`, la app degrada
# a las heurísticas deterministas existentes en `src/lib/ai/*` (P5-4)
# y nunca llama a un proveedor externo.
#
# Modelos por defecto (sobreescribibles vía `LLM_MODEL`):
#   - Anthropic: claude-haiku-4-5-20251001 (rápido, ~3¢/1M in)
#   - OpenAI:    gpt-4o-mini             (rápido, ~15¢/1M in)
#
# `LLM_PROVIDER` admite: anthropic | openai | disabled. Si se omite,
# el adapter detecta automáticamente: prioriza Anthropic si su key
# está presente; si no, OpenAI; si tampoco, `disabled`.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2
LLM_ENABLED=true

# ── Wave P6 · Web Push API (VAPID) ────────────────────────────
# Generar una vez con: npx web-push generate-vapid-keys
# La pública se expone al cliente (NEXT_PUBLIC_*); la privada NUNCA
# debe salir del server. `WEB_PUSH_SUBJECT` debe ser un mailto: o URL
# (RFC 8292): el push service lo usa para contactar al sender si hay
# abuso. Sin estas vars el módulo `src/lib/web-push/server.ts` queda
# en modo skipped (no rompe la app, simplemente no envía push).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
WEB_PUSH_SUBJECT=mailto:notifications@complejoavante.com

# ── Wave R4-E · Stripe SaaS Billing ───────────────────────────
# Documentación detallada: docs/integrations/saas-billing.md
# Server-only secret. Sin esto los endpoints devuelven 503.
STRIPE_SECRET_KEY=
# Bundle público para `@stripe/stripe-js` (loadStripe).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook secret (uno por entorno; lo da `stripe listen` o el dashboard).
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs configurados en el dashboard (products Pro / Enterprise).
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_ENT_MONTHLY=
